php<?php

namespace App\Service;

use Symfony\Contracts\HttpClient\HttpClientInterface;

class GroqInsuranceAssistant
{
    private array $conversationHistory = [];
    private string $systemPrompt;

    public function __construct(
        private HttpClientInterface $httpClient,
        private string $groqApiKey,
        private string $groqApiUrl,
        private string $groqModel,
        ?string $systemPrompt = null,
        array $initialHistory = []
    ) {
        $this->systemPrompt        = $systemPrompt ?? $this->getInsurancePrompt();
        $this->conversationHistory = $initialHistory;
    }

    // =========================================================
    //  PROMPT BUILDERS
    // =========================================================

    private function getInsurancePrompt(): string
    {
        return <<<PROMPT
You are an expert insurance assistant for a fintech platform called FinanceApp.
Your role is to help users with:
- Understanding insurance packages (car and home insurance)
- Explaining coverage details, premiums and risk multipliers
- Guiding users through the contract request process
- Answering questions about insured assets
- Explaining loan and repayment terms
- Helping with budget and expense management questions

Rules:
- Always be professional, concise and friendly
- If a question is completely unrelated to finance or insurance, politely redirect the user
- Format responses clearly, use bullet points when listing multiple items
- Respond in the same language the user writes in (English, French, Arabic, etc.)
- Never invent specific numbers or policy details you don't have
PROMPT;
    }

    public function getInsurancePromptWithContext(array $context): string
    {
        $base = $this->getInsurancePrompt();

        $contextBlock  = "\n\n--- USER CONTEXT (use this to give personalized answers) ---\n";

        if (!empty($context['user'])) {
            $u = $context['user'];
            $contextBlock .= "User: {$u['name']} ({$u['email']})\n";
        }

        if (!empty($context['assets'])) {
            $contextBlock .= "\nInsured Assets:\n";
            foreach ($context['assets'] as $asset) {
                $contextBlock .= "  - [{$asset['type']}] Ref: {$asset['reference']}, "
                    . "Value: {$asset['declaredValue']} TND, "
                    . "Location: {$asset['location']}\n";
            }
        }

        if (!empty($context['contracts'])) {
            $contextBlock .= "\nActive Contract Requests:\n";
            foreach ($context['contracts'] as $contract) {
                $contextBlock .= "  - Asset Ref: {$contract['assetRef']}, "
                    . "Status: {$contract['status']}, "
                    . "Premium: {$contract['premium']} TND\n";
            }
        }

        if (!empty($context['active_loans'])) {
            $contextBlock .= "\nActive Loans:\n";
            foreach ($context['active_loans'] as $loan) {
                $contextBlock .= "  - Amount: {$loan['amount']} TND, "
                    . "Rate: {$loan['interestRate']}%, "
                    . "Status: {$loan['status']}, "
                    . "Due: {$loan['endDate']}\n";
            }
        }

        if (!empty($context['budgets'])) {
            $contextBlock .= "\nBudgets:\n";
            foreach ($context['budgets'] as $budget) {
                $contextBlock .= "  - {$budget['name']}: "
                    . "{$budget['spentAmount']}/{$budget['amount']} TND spent "
                    . "({$budget['category']})\n";
            }
        }

        $contextBlock .= "--- END OF CONTEXT ---\n";

        return $base . $contextBlock;
    }

    // =========================================================
    //  MEMORY MANAGEMENT
    // =========================================================

    public function withPrompt(string $prompt): static
    {
        $clone               = clone $this;
        $clone->systemPrompt = $prompt;
        return $clone;
    }

    public function withContext(array $context): static
    {
        $clone               = clone $this;
        $clone->systemPrompt = $this->getInsurancePromptWithContext($context);
        return $clone;
    }

    public function withHistory(array $history): static
    {
        $clone                      = clone $this;
        $clone->conversationHistory = $history;
        return $clone;
    }

    public function getHistory(): array
    {
        return $this->conversationHistory;
    }

    public function getSystemPrompt(): string
    {
        return $this->systemPrompt;
    }

    public function clearHistory(): static
    {
        $clone                      = clone $this;
        $clone->conversationHistory = [];
        return $clone;
    }

    // =========================================================
    //  PUBLIC API
    // =========================================================

    public function ask(string $userMessage): string
    {
        $reply = $this->sendToGroq($userMessage);

        // Append to internal memory
        $this->conversationHistory[] = ['role' => 'user',      'content' => $userMessage];
        $this->conversationHistory[] = ['role' => 'assistant',  'content' => $reply];

        // Keep last 20 messages to avoid token overflow
        if (count($this->conversationHistory) > 20) {
            $this->conversationHistory = array_slice($this->conversationHistory, -20);
        }

        return $reply;
    }

    // =========================================================
    //  PRIVATE — HTTP CALL
    // =========================================================

    private function sendToGroq(string $userMessage): string
    {
        $messages = [
            ['role' => 'system', 'content' => $this->systemPrompt],
            ...$this->conversationHistory,
            ['role' => 'user', 'content' => $userMessage],
        ];

        $response = $this->httpClient->request('POST', $this->groqApiUrl, [
            'headers' => [
                'Authorization' => 'Bearer ' . $this->groqApiKey,
                'Content-Type'  => 'application/json',
            ],
            'json' => [
                'model'       => $this->groqModel,
                'messages'    => $messages,
                'max_tokens'  => 1024,
                'temperature' => 0.7,
            ],
        ]);

        $data = $response->toArray();

        return $data['choices'][0]['message']['content']
            ?? 'Sorry, I could not process your request.';
    }
}

