php<?php

namespace App\Controller;

use App\Service\GroqInsuranceAssistant;
use Doctrine\ORM\EntityManagerInterface;
use Symfony\Bundle\FrameworkBundle\Controller\AbstractController;
use Symfony\Component\HttpFoundation\JsonResponse;
use Symfony\Component\HttpFoundation\Request;
use Symfony\Component\HttpFoundation\Response;
use Symfony\Component\Routing\Attribute\Route;

class AssistantController extends AbstractController
{
    public function __construct(
        private GroqInsuranceAssistant $assistant,
        private EntityManagerInterface $em
    ) {}

    #[Route('/assistant', name: 'app_assistant')]
    public function index(): Response
    {
        return $this->render('assistant/index.html.twig');
    }

    #[Route('/assistant/chat', name: 'app_assistant_chat', methods: ['POST'])]
    public function chat(Request $request): JsonResponse
    {
        $data    = json_decode($request->getContent(), true);
        $message = $data['message'] ?? '';
        $history = $data['history'] ?? [];
        $userId  = $data['user_id'] ?? null;

        if (empty($message)) {
            return $this->json(['error' => 'Empty message'], 400);
        }

        try {
            // Start from the injected service, rebuild with session history + context
            $assistant = $this->assistant->withHistory($history);

            if ($userId) {
                $context   = $this->buildUserContext((int) $userId);
                $assistant = $assistant->withContext($context);
            }

            $reply = $assistant->ask($message);

            return $this->json([
                'reply'   => $reply,
                // Send updated history back to browser so next request stays in sync
                'history' => $assistant->getHistory(),
            ]);

        } catch (\Exception $e) {
            return $this->json([
                'error' => 'Assistant unavailable: ' . $e->getMessage()
            ], 500);
        }
    }

    private function buildUserContext(int $userId): array
    {
        $user = $this->em->getRepository(\App\Entity\User::class)->find($userId);

        if (!$user) return [];

        $assets = array_map(fn($a) => [
            'type'          => $a->getType(),
            'reference'     => $a->getReference(),
            'declaredValue' => $a->getDeclaredValue(),
            'location'      => $a->getLocation(),
        ], $user->getInsuredAssets()->toArray());

        $contracts = [];
        foreach ($user->getInsuredAssets() as $asset) {
            foreach ($asset->getContractRequests() as $cr) {
                $contracts[] = [
                    'assetRef' => $asset->getReference(),
                    'status'   => $cr->getStatus(),
                    'premium'  => $cr->getCalculatedPremium(),
                ];
            }
        }

        $loans = array_map(fn($l) => [
            'amount'       => $l->getAmount(),
            'interestRate' => $l->getInterestRate(),
            'status'       => $l->getStatus(),
            'endDate'      => $l->getEndDate()->format('Y-m-d'),
        ], $user->getLoans()->toArray());

        $budgets = array_map(fn($b) => [
            'name'        => $b->getName(),
            'amount'      => $b->getAmount(),
            'spentAmount' => $b->getSpentAmount(),
            'category'    => $b->getCategory(),
        ], $user->getBudgets()->toArray());

        return [
            'user'         => ['name' => $user->getName(), 'email' => $user->getEmail()],
            'assets'       => $assets,
            'contracts'    => $contracts,
            'active_loans' => $loans,
            'budgets'      => $budgets,
        ];
    }
}

