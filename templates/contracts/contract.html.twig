<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
    body        { font-family: Arial, sans-serif; font-size: 13px; color: #222; margin: 40px; }
    h1          { text-align: center; font-size: 20px; margin-bottom: 4px; }
    .subtitle   { text-align: center; color: #555; margin-bottom: 30px; }
    table       { width: 100%; border-collapse: collapse; margin: 20px 0; }
    th, td      { border: 1px solid #ccc; padding: 8px 12px; }
    th          { background: #f0f4ff; width: 35%; }
    .terms      { margin-top: 30px; font-size: 12px; color: #444; line-height: 1.7; }
    .signature  { margin-top: 60px; display: flex; justify-content: space-between; }
    .sig-block  { text-align: center; width: 45%; }
    .sig-line   { border-top: 1px solid #333; margin-top: 50px; padding-top: 6px; font-size: 12px; }
</style>
</head>
<body>

<h1>Insurance Contract</h1>
<p class="subtitle">Reference: {{ assetReference }}</p>

<table>
    <tr><th>Insured Party</th>    <td>{{ userName }}</td></tr>
    <tr><th>Asset Reference</th>  <td>{{ assetReference }}</td></tr>
    <tr><th>Insurance Package</th><td>{{ insurancePackage }}</td></tr>
    <tr><th>Approved Value</th>   <td>{{ approvedValue }}</td></tr>
    <tr><th>Contract Date</th>    <td>{{ contractDate }}</td></tr>
</table>

<div class="terms">
    <strong>Terms &amp; Conditions</strong>
    <p>{{ terms }}</p>
</div>

<div class="signature">
    <div class="sig-block">
        <div class="sig-line">Insured — {{ userName }}</div>
    </div>
    <div class="sig-block">
        <div class="sig-line">Authorised Representative</div>
    </div>
</div>

</body>
</html>