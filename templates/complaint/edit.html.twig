{% extends 'base.html.twig' %}

{% block title %}Edit Complaint{% endblock %}
{% block page_title %}Edit Complaint{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header"><h3 class="card-title"><i class="bi bi-pencil-square me-2"></i>Edit Complaint</h3></div>
            <div class="card-body">
                <p class="text-muted mb-4">You can update your complaint description below. Only pending complaints can be edited.</p>
                <form method="post" action="{{ path('complaint_edit', {'id': complaint.id}) }}">
                    {% for message in app.flashes('danger') %}
                        <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>{{ message }}</div>
                    {% endfor %}
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
                        <textarea name="subject" class="form-control" rows="6" required>{{ complaint.subject }}</textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Update Complaint</button>
                        <a href="{{ path('complaint_index') }}" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
