{% extends 'base.html.twig' %}

{% block title %}My Complaints{% endblock %}
{% block page_title %}My Complaints{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">Submit issues or feedback and track admin responses.</p>
    <a href="{{ path('complaint_new') }}" class="btn btn-primary">
        <i class="bi bi-chat-left-text me-1"></i> New Complaint
    </a>
</div>

{% for msg in app.flashes('success') %}<div class="alert alert-success alert-dismissible fade show">{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>{% endfor %}

<div class="card shadow-sm">
    <div class="card-header">
        <h3 class="card-title"><i class="bi bi-megaphone me-2"></i>Complaint History</h3>
        <span class="badge bg-secondary ms-2">{{ complaints|length }} total</span>
    </div>
    <div class="card-body p-0">
        {% if complaints is empty %}
            <div class="text-center py-5 text-muted">
                <i class="bi bi-chat-square-text" style="font-size:3rem;"></i>
                <p class="mt-2">You have no complaints submitted yet.</p>
            </div>
        {% else %}
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>#</th><th>Subject</th><th>Date</th><th>Status</th><th>Response</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                {% for c in complaints %}
                    <tr>
                        <td>{{ c.id }}</td>
                        <td>{{ c.subject|slice(0, 70) }}{% if c.subject|length > 70 %}…{% endif %}</td>
                        <td>{{ c.complaintDate|date('d/m/Y') }}</td>
                        <td>
                            {% if c.status == 'resolved' %}<span class="badge bg-success">Resolved</span>
                            {% elseif c.status == 'in_progress' %}<span class="badge bg-info">In Progress</span>
                            {% else %}<span class="badge bg-warning text-dark">Pending</span>{% endif %}
                        </td>
                        <td>
                            {% if c.response %}
                                <i class="bi bi-check2-circle text-success" title="Admin responded"></i> Received
                            {% else %}
                                <span class="text-muted small">Awaiting</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-1">
                                <a href="{{ path('complaint_show', {id: c.id}) }}" class="btn btn-sm btn-outline-primary" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                {% if c.status == 'pending' %}
                                <a href="{{ path('complaint_edit', {id: c.id}) }}" class="btn btn-sm btn-outline-secondary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                {% endif %}
                                <form method="post" action="{{ path('complaint_delete', {id: c.id}) }}" onsubmit="return confirm('Are you sure you want to delete this complaint?');" style="display: inline-block;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_complaint' ~ c.id) }}">
                                    <button class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}
