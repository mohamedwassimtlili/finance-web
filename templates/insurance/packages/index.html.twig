{% extends 'base.html.twig' %}
{% block title %}Insurance Packages{% endblock %}
{% block page_title %}Available Insurance Packages{% endblock %}

{% block body %}

{# ── Search / Filter / Sort ── #}
<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body py-2">
        <form method="get" action="{{ path('insurance_packages') }}" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small text-muted mb-1">Search</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="q" value="{{ q }}" class="form-control" placeholder="Package name, coverage details…">
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Asset Type</label>
                <select name="asset_type" class="form-select">
                    <option value="">All types</option>
                    {% for t in ['Vehicle', 'Property', 'Equipment', 'Electronics', 'Livestock', 'Other'] %}
                        <option value="{{ t }}" {{ assetType == t ? 'selected' : '' }}>{{ t }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted mb-1">Sort by</label>
                <select name="order" class="form-select">
                    <option value="p.name"           {{ orderBy == 'p.name'           ? 'selected' : '' }}>Name</option>
                    <option value="p.basePrice"      {{ orderBy == 'p.basePrice'      ? 'selected' : '' }}>Base Price</option>
                    <option value="p.durationMonths" {{ orderBy == 'p.durationMonths' ? 'selected' : '' }}>Duration</option>
                    <option value="p.riskMultiplier" {{ orderBy == 'p.riskMultiplier' ? 'selected' : '' }}>Risk Multiplier</option>
                </select>
            </div>
            <div class="col-md-1">
                <label class="form-label small text-muted mb-1">Dir</label>
                <select name="dir" class="form-select">
                    <option value="ASC"  {{ dir == 'ASC'  ? 'selected' : '' }}>↑ Asc</option>
                    <option value="DESC" {{ dir == 'DESC' ? 'selected' : '' }}>↓ Desc</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-100"><i class="bi bi-funnel me-1"></i>Filter</button>
                <a href="{{ path('insurance_packages') }}" class="btn btn-outline-secondary" title="Reset"><i class="bi bi-x-lg"></i></a>
            </div>
        </form>
    </div>
</div>

<p class="text-muted mb-3">{{ packages|length }} package(s) found</p>

<div class="row g-4">
    {% for package in packages %}
    <div class="col-lg-4 col-md-6">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-header bg-primary text-white">
                <h5 class="card-title mb-0"><i class="bi bi-shield-fill me-2"></i>{{ package.name }}</h5>
                <small class="opacity-75">{{ package.assetType|capitalize }}</small>
            </div>
            <div class="card-body">
                <p class="text-muted small">{{ package.description }}</p>
                {% if package.coverageDetails %}
                    <p class="small"><strong>Coverage:</strong> {{ package.coverageDetails }}</p>
                {% endif %}
                <ul class="list-unstyled mt-3">
                    <li><i class="bi bi-cash-coin text-success me-2"></i><strong>Base Price:</strong> {{ package.basePrice }} TND</li>
                    <li><i class="bi bi-graph-up text-warning me-2"></i><strong>Risk Multiplier:</strong> ×{{ package.riskMultiplier }}</li>
                    <li><i class="bi bi-calendar3 text-info me-2"></i><strong>Duration:</strong> {{ package.durationMonths }} months</li>
                    <li class="mt-2 fw-bold text-primary fs-6">
                        Estimated Premium: {{ (package.basePrice * package.riskMultiplier)|number_format(2) }} TND
                    </li>
                </ul>
            </div>
            <div class="card-footer bg-transparent d-flex flex-column gap-2">
                <a href="{{ path('insurance_request_new') }}?package={{ package.id }}"
                   class="btn btn-primary w-100">
                    <i class="bi bi-file-earmark-plus me-1"></i>Request This Package
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                <div class="d-flex gap-2">
                    <a href="{{ path('admin_insurance_package_edit', {id: package.id}) }}"
                       class="btn btn-outline-warning btn-sm flex-fill">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <form method="post" action="{{ path('admin_insurance_package_delete', {id: package.id}) }}"
                          class="flex-fill" onsubmit="return confirm('Delete package {{ package.name }}?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-pkg-' ~ package.id) }}">
                        <button class="btn btn-outline-danger btn-sm w-100">
                            <i class="bi bi-trash me-1"></i>Delete
                        </button>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
    {% else %}
    <div class="col-12">
        <div class="alert alert-info">No packages found for the current filters.</div>
    </div>
    {% endfor %}
</div>
{% endblock %}
