{% extends 'base.html.twig' %}
{% block title %}My Assets{% endblock %}
{% block page_title %}My Insured Assets{% endblock %}

{% block body %}
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endfor %}

{# ── Search / Filter / Sort ── #}
<div class="card mb-3 border-0 shadow-sm">
    <div class="card-body py-2">
        <form method="get" action="{{ path('insurance_assets') }}" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small text-muted mb-1">Search</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="q" value="{{ q }}" class="form-control" placeholder="Reference, brand, location…">
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Type</label>
                <select name="type" class="form-select">
                    <option value="">All types</option>
                    {% for t in ['Vehicle', 'Property', 'Equipment', 'Electronics', 'Livestock', 'Other'] %}
                        <option value="{{ t }}" {{ type == t ? 'selected' : '' }}>{{ t }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted mb-1">Sort by</label>
                <select name="order" class="form-select">
                    <option value="a.createdAt"       {{ orderBy == 'a.createdAt'       ? 'selected' : '' }}>Date Added</option>
                    <option value="a.reference"       {{ orderBy == 'a.reference'       ? 'selected' : '' }}>Reference</option>
                    <option value="a.brand"           {{ orderBy == 'a.brand'           ? 'selected' : '' }}>Brand</option>
                    <option value="a.declaredValue"   {{ orderBy == 'a.declaredValue'   ? 'selected' : '' }}>Declared Value</option>
                    <option value="a.manufactureDate" {{ orderBy == 'a.manufactureDate' ? 'selected' : '' }}>Manufacture Date</option>
                </select>
            </div>
            <div class="col-md-1">
                <label class="form-label small text-muted mb-1">Dir</label>
                <select name="dir" class="form-select">
                    <option value="DESC" {{ dir == 'DESC' ? 'selected' : '' }}>↓ Desc</option>
                    <option value="ASC"  {{ dir == 'ASC'  ? 'selected' : '' }}>↑ Asc</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-100"><i class="bi bi-funnel me-1"></i>Filter</button>
                <a href="{{ path('insurance_assets') }}" class="btn btn-outline-secondary" title="Reset"><i class="bi bi-x-lg"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="row mb-3">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <p class="text-muted mb-0">{{ assets|length }} asset(s) found</p>
        <a href="{{ path('insurance_asset_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Register New Asset
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header"><h3 class="card-title"><i class="bi bi-shield-check me-2"></i>Assets</h3></div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>
                        <a href="{{ path('insurance_assets', {q: q, type: type, order: 'a.reference', dir: (orderBy == 'a.reference' and dir == 'ASC') ? 'DESC' : 'ASC'}) }}" class="text-decoration-none text-dark">
                            Reference {% if orderBy == 'a.reference' %}<i class="bi bi-arrow-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                        </a>
                    </th>
                    <th>Type</th>
                    <th>
                        <a href="{{ path('insurance_assets', {q: q, type: type, order: 'a.brand', dir: (orderBy == 'a.brand' and dir == 'ASC') ? 'DESC' : 'ASC'}) }}" class="text-decoration-none text-dark">
                            Brand {% if orderBy == 'a.brand' %}<i class="bi bi-arrow-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                        </a>
                    </th>
                    <th>
                        <a href="{{ path('insurance_assets', {q: q, type: type, order: 'a.declaredValue', dir: (orderBy == 'a.declaredValue' and dir == 'ASC') ? 'DESC' : 'ASC'}) }}" class="text-decoration-none text-dark">
                            Declared Value {% if orderBy == 'a.declaredValue' %}<i class="bi bi-arrow-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                        </a>
                    </th>
                    <th>Approved Value</th>
                    <th>
                        <a href="{{ path('insurance_assets', {q: q, type: type, order: 'a.manufactureDate', dir: (orderBy == 'a.manufactureDate' and dir == 'ASC') ? 'DESC' : 'ASC'}) }}" class="text-decoration-none text-dark">
                            Manufacture Date {% if orderBy == 'a.manufactureDate' %}<i class="bi bi-arrow-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                        </a>
                    </th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for asset in assets %}
                <tr>
                    <td>{{ asset.id }}</td>
                    <td>{{ asset.reference }}</td>
                    <td><span class="badge text-bg-secondary">{{ asset.type }}</span></td>
                    <td>{{ asset.brand }}</td>
                    <td>{{ asset.declaredValue }} TND</td>
                    <td>{{ asset.approvedValue ? asset.approvedValue ~ ' TND' : '<span class="text-muted">Pending</span>'|raw }}</td>
                    <td>{{ asset.manufactureDate|date('Y-m-d') }}</td>
                    <td>
                        <a href="{{ path('insurance_asset_edit', {id: asset.id}) }}" class="btn btn-sm btn-outline-warning">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form method="post" action="{{ path('insurance_asset_delete', {id: asset.id}) }}" class="d-inline"
                              onsubmit="return confirm('Delete this asset?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-asset-' ~ asset.id) }}">
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                        <a href="{{ path('insurance_request_new') }}?asset={{ asset.id }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-file-earmark-plus"></i> Request
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="8" class="text-center text-muted py-4">No assets found for the current filters.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
