{% extends 'base.html.twig' %}
{% block title %}My Contract Requests{% endblock %}
{% block page_title %}My Insurance Contract Requests{% endblock %}

{% block body %}
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label }} alert-dismissible fade show">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endfor %}

<div class="row mb-3">
    <div class="col-12 d-flex justify-content-end">
        <a href="{{ path('insurance_request_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> New Contract Request
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header"><h3 class="card-title"><i class="bi bi-file-earmark-text me-2"></i>Requests</h3></div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Asset</th>
                    <th>Package</th>
                    <th>Premium</th>
                    <th>Status</th>
                    <th>Submitted</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for req in requests %}
                {% set statusClass = {
                    'PENDING':   'warning',
                    'APPROVED':  'success',
                    'REJECTED':  'danger',
                    'CANCELLED': 'secondary'
                }[req.status] ?? 'secondary' %}
                <tr>
                    <td>{{ req.id }}</td>
                    <td>{{ req.asset.reference }} <small class="text-muted">({{ req.asset.type }})</small></td>
                    <td>{{ req.package.name }}</td>
                    <td>{{ req.calculatedPremium }} TND</td>
                    <td><span class="badge text-bg-{{ statusClass }}">{{ req.status }}</span></td>
                    <td>{{ req.createdAt ? req.createdAt|date('Y-m-d') : '—' }}</td>
                    <td>
                        {% if req.status == 'PENDING' %}
                        <form method="post" action="{{ path('insurance_request_cancel', {id: req.id}) }}" class="d-inline"
                              onsubmit="return confirm('Cancel this request?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('cancel-req-' ~ req.id) }}">
                            <button class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-x-circle"></i> Cancel
                            </button>
                        </form>
                        {% else %}
                            <span class="text-muted small">—</span>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="7" class="text-center text-muted py-4">No contract requests yet.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
