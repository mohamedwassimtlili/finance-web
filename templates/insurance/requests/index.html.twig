{% extends 'base.html.twig' %}
{% block title %}My Contract Requests{% endblock %}
{% block page_title %}My Insurance Contract Requests{% endblock %}

{% block body %}
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label }} alert-dismissible fade show">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endfor %}

{# ── Search / Filter / Sort ── #}
<div class="card mb-3 border-0 shadow-sm">
    <div class="card-body py-2">
        <form method="get" action="{{ path('insurance_requests') }}" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small text-muted mb-1">Search</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="q" value="{{ q }}" class="form-control" placeholder="Asset reference, package name…">
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Status</label>
                <select name="status" class="form-select">
                    <option value="">All statuses</option>
                    {% for s in ['PENDING', 'APPROVED', 'REJECTED', 'CANCELLED'] %}
                        <option value="{{ s }}" {{ status == s ? 'selected' : '' }}>{{ s|capitalize }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted mb-1">Sort by</label>
                <select name="order" class="form-select">
                    <option value="r.createdAt"         {{ orderBy == 'r.createdAt'         ? 'selected' : '' }}>Submitted Date</option>
                    <option value="r.calculatedPremium" {{ orderBy == 'r.calculatedPremium' ? 'selected' : '' }}>Premium</option>
                    <option value="r.status"            {{ orderBy == 'r.status'            ? 'selected' : '' }}>Status</option>
                </select>
            </div>
            <div class="col-md-1">
                <label class="form-label small text-muted mb-1">Dir</label>
                <select name="dir" class="form-select">
                    <option value="DESC" {{ dir == 'DESC' ? 'selected' : '' }}>↓ Desc</option>
                    <option value="ASC"  {{ dir == 'ASC'  ? 'selected' : '' }}>↑ Asc</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-100"><i class="bi bi-funnel me-1"></i>Filter</button>
                <a href="{{ path('insurance_requests') }}" class="btn btn-outline-secondary" title="Reset"><i class="bi bi-x-lg"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="row mb-3">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <p class="text-muted mb-0">{{ requests|length }} request(s) found</p>
        <a href="{{ path('insurance_request_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> New Contract Request
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header"><h3 class="card-title"><i class="bi bi-file-earmark-text me-2"></i>Requests</h3></div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Asset</th>
                    <th>Package</th>
                    <th>
                        <a href="{{ path('insurance_requests', {q: q, status: status, order: 'r.calculatedPremium', dir: (orderBy == 'r.calculatedPremium' and dir == 'ASC') ? 'DESC' : 'ASC'}) }}" class="text-decoration-none text-dark">
                            Premium {% if orderBy == 'r.calculatedPremium' %}<i class="bi bi-arrow-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                        </a>
                    </th>
                    <th>
                        <a href="{{ path('insurance_requests', {q: q, status: status, order: 'r.status', dir: (orderBy == 'r.status' and dir == 'ASC') ? 'DESC' : 'ASC'}) }}" class="text-decoration-none text-dark">
                            Status {% if orderBy == 'r.status' %}<i class="bi bi-arrow-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                        </a>
                    </th>
                    <th>
                        <a href="{{ path('insurance_requests', {q: q, status: status, order: 'r.createdAt', dir: (orderBy == 'r.createdAt' and dir == 'ASC') ? 'DESC' : 'ASC'}) }}" class="text-decoration-none text-dark">
                            Submitted {% if orderBy == 'r.createdAt' %}<i class="bi bi-arrow-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                        </a>
                    </th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for req in requests %}
                {% set statusClass = {
                    'PENDING':   'warning',
                    'APPROVED':  'success',
                    'REJECTED':  'danger',
                    'CANCELLED': 'secondary'
                }[req.status] ?? 'secondary' %}
                <tr>
                    <td>{{ req.id }}</td>
                    <td>{{ req.asset.reference }} <small class="text-muted">({{ req.asset.type }})</small></td>
                    <td>{{ req.package.name }}</td>
                    <td>{{ req.calculatedPremium }} TND</td>
                    <td><span class="badge text-bg-{{ statusClass }}">{{ req.status }}</span></td>
                    <td>{{ req.createdAt ? req.createdAt|date('Y-m-d') : '—' }}</td>
                    <td class="text-nowrap">
                        {# ── Edit ── #}
                        <a href="{{ path('insurance_request_edit', {id: req.id}) }}"
                           class="btn btn-sm btn-outline-warning me-1" title="Edit">
                            <i class="bi bi-pencil"></i>
                        </a>

                        {# ── Cancel: only for PENDING ── #}
                        {% if req.status == 'PENDING' %}
                        <form method="post" action="{{ path('insurance_request_cancel', {id: req.id}) }}" class="d-inline"
                              onsubmit="return confirm('Cancel this request?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('cancel-req-' ~ req.id) }}">
                            <button class="btn btn-sm btn-outline-secondary me-1" title="Cancel">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        </form>
                        {% endif %}

                        {# ── Delete ── #}
                        <form method="post" action="{{ path('insurance_request_delete', {id: req.id}) }}" class="d-inline"
                              onsubmit="return confirm('Delete request #{{ req.id }}?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-req-' ~ req.id) }}">
                            <button class="btn btn-sm btn-outline-danger" title="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="7" class="text-center text-muted py-4">No requests found for the current filters.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
