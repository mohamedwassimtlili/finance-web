{% extends 'base.html.twig' %}

{% block title %}My Repayments{% endblock %}
{% block page_title %}My Repayments{% endblock %}

{% block body %}
<div class="card shadow-sm">
    <div class="card-header">
        <h3 class="card-title"><i class="bi bi-calendar-check me-2"></i>All My Repayments</h3>
        <span class="badge bg-secondary ms-2">{{ repayments|length }} total</span>
    </div>
    <div class="card-body p-0">
        {% if repayments is empty %}
            <div class="text-center py-5 text-muted">
                <i class="bi bi-calendar-x" style="font-size:3rem;"></i>
                <p class="mt-2">No repayments recorded yet.</p>
                <a href="{{ path('loan_index') }}" class="btn btn-outline-primary btn-sm mt-1">View My Loans</a>
            </div>
        {% else %}
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Loan #</th>
                        <th>Amount (TND)</th>
                        <th>Payment Date</th>
                        <th>Type</th>
                        <th>Monthly Payment</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for r in repayments %}
                    <tr>
                        <td>{{ r.id }}</td>
                        <td>
                            <a href="{{ path('loan_show', {id: r.loan.id}) }}" class="text-decoration-none">
                                Loan #{{ r.loan.id }}
                            </a>
                        </td>
                        <td>{{ r.amount|number_format(2, '.', ',') }}</td>
                        <td>{{ r.paymentDate|date('d/m/Y') }}</td>
                        <td>{{ r.paymentType|default('—') }}</td>
                        <td>{{ r.monthlyPayment ? r.monthlyPayment|number_format(2, '.', ',') ~ ' TND' : '—' }}</td>
                        <td>
                            {% if r.status == 'paid' %}
                                <span class="badge bg-success">Paid</span>
                            {% elseif r.status == 'pending' %}
                                <span class="badge bg-warning text-dark">Pending</span>
                            {% else %}
                                <span class="badge bg-secondary">{{ r.status }}</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            {% if r.status == 'pending' %}
                                <form method="post" action="{{ path('loan_repayment_confirm', {id: r.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('confirm_repayment_' ~ r.id) }}">
                                    <button class="btn btn-sm btn-success" onclick="return confirm('Mark this repayment as paid?')">
                                        <i class="bi bi-check-circle"></i> Confirm
                                    </button>
                                </form>
                            {% else %}
                                <span class="text-muted small">—</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}
