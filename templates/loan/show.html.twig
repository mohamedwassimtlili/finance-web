{% extends 'base.html.twig' %}

{% block title %}Loan #{{ loan.id }}{% endblock %}
{% block page_title %}Loan #{{ loan.id }} — Details{% endblock %}

{% block body %}
{% for msg in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">
        {{ msg }} <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

{# ── Loan summary card ── #}
<div class="row mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h3 class="card-title"><i class="bi bi-bank me-2"></i>Loan Information</h3>
            </div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <tr><th style="width:45%">Amount</th><td>{{ loan.amount|number_format(2, '.', ',') }} TND</td></tr>
                    <tr><th>Interest Rate</th><td>{{ loan.interestRate }}%</td></tr>
                    <tr><th>Start Date</th><td>{{ loan.startDate|date('d/m/Y') }}</td></tr>
                    <tr><th>End Date</th><td>{{ loan.endDate|date('d/m/Y') }}</td></tr>
                    <tr><th>Status</th>
                        <td>
                            {% if loan.status == 'active' %}<span class="badge bg-success">Active</span>
                            {% elseif loan.status == 'paid' %}<span class="badge bg-secondary">Paid</span>
                            {% elseif loan.status == 'defaulted' %}<span class="badge bg-danger">Defaulted</span>
                            {% else %}<span class="badge bg-info">{{ loan.status|capitalize }}</span>{% endif %}
                        </td>
                    </tr>
                    <tr><th>Created At</th><td>{{ loan.createdAt ? loan.createdAt|date('d/m/Y H:i') : 'N/A' }}</td></tr>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h3 class="card-title"><i class="bi bi-pie-chart me-2"></i>Repayment Summary</h3>
            </div>
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                <h2 class="text-primary">{{ totalPaid|number_format(2, '.', ',') }} TND</h2>
                <p class="text-muted mb-1">Total paid out of</p>
                <h4>{{ loan.amount|number_format(2, '.', ',') }} TND</h4>
                {% set pct = loan.amount > 0 ? (totalPaid / loan.amount * 100)|round : 0 %}
                <div class="progress w-100 mt-3" style="height:18px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width:{{ pct }}%">{{ pct }}%</div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Repayments table ── #}
<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0"><i class="bi bi-calendar-check me-2"></i>Repayments</h3>
        <a href="{{ path('loan_repayment_new', {id: loan.id}) }}" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add Repayment
        </a>
    </div>
    <div class="card-body p-0">
        {% if repayments is empty %}
            <div class="text-center py-4 text-muted">
                <i class="bi bi-calendar-x" style="font-size:2.5rem;"></i>
                <p class="mt-2">No repayments recorded yet.</p>
            </div>
        {% else %}
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Amount (TND)</th>
                        <th>Payment Date</th>
                        <th>Type</th>
                        <th>Monthly Payment</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                {% for r in repayments %}
                    <tr>
                        <td>{{ r.id }}</td>
                        <td>{{ r.amount|number_format(2, '.', ',') }}</td>
                        <td>{{ r.paymentDate|date('d/m/Y') }}</td>
                        <td>{{ r.paymentType|default('—') }}</td>
                        <td>{{ r.monthlyPayment ? r.monthlyPayment|number_format(2, '.', ',') ~ ' TND' : '—' }}</td>
                        <td>
                            {% if r.status == 'paid' %}<span class="badge bg-success">Paid</span>
                            {% elseif r.status == 'pending' %}<span class="badge bg-warning text-dark">Pending</span>
                            {% else %}<span class="badge bg-secondary">{{ r.status }}</span>{% endif %}
                        </td>
                        <td class="text-end">
                            {% if r.status == 'pending' %}
                                <form method="post" action="{{ path('loan_repayment_confirm', {id: r.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('confirm_repayment_' ~ r.id) }}">
                                    <button class="btn btn-sm btn-success" onclick="return confirm('Mark this repayment as paid?')">
                                        <i class="bi bi-check-circle"></i> Confirm
                                    </button>
                                </form>
                            {% else %}
                                <span class="text-muted small">—</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>

<div class="mt-3">
    <a href="{{ path('loan_index') }}" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to My Loans
    </a>
</div>
{% endblock %}
