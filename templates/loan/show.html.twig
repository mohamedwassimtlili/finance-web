{% extends 'base.html.twig' %}

{% block title %}Loan #{{ loan.id }}{% endblock %}
{% block page_title %}Loan #{{ loan.id }} — Details{% endblock %}

{% block body %}
{% for msg in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">
        {{ msg }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

{% for msg in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show">
        {{ msg }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h3 class="card-title mb-0"><i class="bi bi-bank me-2"></i>Loan Information</h3>
            </div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <tr>
                        <th style="width:45%">Amount</th>
                        <td>{{ loan.amount|number_format(2, '.', ',') }} TND</td>
                    </tr>
                    <tr>
                        <th>Interest Rate</th>
                        <td>{{ loan.interestRate }}%</td>
                    </tr>
                    <tr>
                        <th>Start Date</th>
                        <td>{{ loan.startDate|date('d/m/Y') }}</td>
                    </tr>
                    <tr>
                        <th>End Date</th>
                        <td>{{ loan.endDate|date('d/m/Y') }}</td>
                    </tr>
                    <tr>
                        <th>Status</th>
                        <td>
                            {% if loan.status == 'active' %}
                                <span class="badge bg-success">Active</span>
                            {% elseif loan.status == 'paid' %}
                                <span class="badge bg-secondary">Paid</span>
                            {% elseif loan.status == 'defaulted' %}
                                <span class="badge bg-danger">Defaulted</span>
                            {% else %}
                                <span class="badge bg-info">{{ loan.status|capitalize }}</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th>Created At</th>
                        <td>{{ loan.createdAt ? loan.createdAt|date('d/m/Y H:i') : 'N/A' }}</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h3 class="card-title mb-0"><i class="bi bi-pie-chart me-2"></i>Repayment Summary</h3>
            </div>
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                <h2 class="text-primary">{{ totalPaid|number_format(2, '.', ',') }} TND</h2>
                <p class="text-muted mb-1">Total paid out of</p>
                <h4>{{ loan.amount|number_format(2, '.', ',') }} TND</h4>
                {% set pct = loan.amount > 0 ? (totalPaid / loan.amount * 100)|round : 0 %}
                <div class="progress w-100 mt-3" style="height:18px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width:{{ pct }}%">{{ pct }}%</div>
                </div>
            </div>
        </div>
    </div>
</div>

{# AI SIMULATOR SECTION #}
<div class="row mb-4">
    <div class="col-md-5">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-light">
                <h3 class="card-title mb-0"><i class="bi bi-rocket-takeoff me-2"></i>Payoff Simulator</h3>
            </div>
            <div class="card-body">
                <label class="form-label fw-bold">Monthly Installment</label>
                <input type="range" class="form-range" id="paymentSlider" min="50" max="{{ loan.amount }}" step="50" value="500">
                
                <div class="d-flex justify-content-between mt-3 p-3 bg-light rounded">
                    <div>
                        <small class="text-muted d-block">Monthly</small>
                        <span class="h4 mb-0" id="monthlyDisplay">500</span> <small>TND</small>
                    </div>
                    <div class="text-end">
                        <small class="text-muted d-block">Clearance</small>
                        <span class="h4 mb-0 text-primary" id="monthsDisplay">--</span> <small>Months</small>
                    </div>
                </div>

                <div class="mt-3 p-3 border-start border-4 border-primary bg-light">
                    <h6><i class="bi bi-cpu me-2"></i>Live AI Feedback</h6>
                    <p id="aiFeedback" class="small mb-1">Adjust the slider to see analysis...</p>
                    <span id="riskBadge" class="badge bg-secondary">Waiting...</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h3 class="card-title mb-0"><i class="bi bi-graph-down-arrow me-2"></i>Predicted Debt Trajectory</h3>
            </div>
            <div class="card-body">
                <canvas id="debtChart" style="max-height: 250px;"></canvas>
            </div>
        </div>
    </div>
</div>

{# REPAYMENTS SECTION #}
<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0"><i class="bi bi-calendar-check me-2"></i>Repayments</h3>
        <a href="{{ path('loan_repayment_new', {id: loan.id}) }}" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add Repayment
        </a>
    </div>
    <div class="card-body p-0">
        {% if repayments is empty %}
            <div class="text-center py-4 text-muted">
                <i class="bi bi-calendar-x" style="font-size:2.5rem;"></i>
                <p class="mt-2">No repayments recorded yet.</p>
            </div>
        {% else %}
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Amount (TND)</th>
                        <th>Payment Date</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                {% for r in repayments %}
                    <tr>
                        <td>{{ r.id }}</td>
                        <td>{{ r.amount|number_format(2, '.', ',') }}</td>
                        <td>{{ r.paymentDate|date('d/m/Y') }}</td>
                        <td>
                            {% if r.status == 'paid' %}
                                <span class="badge bg-success">Paid</span>
                            {% elseif r.status == 'pending' %}
                                <span class="badge bg-warning text-dark">Pending</span>
                            {% else %}
                                <span class="badge bg-secondary">{{ r.status|capitalize }}</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <form method="post" action="{{ path('loan_delete', {id: loan.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ loan.id) }}">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>

<div class="mt-3 d-flex gap-2 flex-wrap">
    <a href="{{ path('loan_index') }}" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to My Loans
    </a>
    <a href="{{ path('loan_edit', {id: loan.id}) }}" class="btn btn-outline-primary">
        <i class="bi bi-pencil me-1"></i>Edit Loan
    </a>
    <a href="{{ path('loan_invoice', {id: loan.id}) }}" class="btn btn-danger">
        <i class="bi bi-file-earmark-pdf me-1"></i>Invoice
    </a>
    <a href="{{ path('loan_analyse', {id: loan.id}) }}" class="btn btn-dark">
        <i class="bi bi-robot me-1"></i>AI Analysis
    </a>
</div>

{# JAVASCRIPT FOR CHART AND SIMULATOR #}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const slider = document.getElementById('paymentSlider');
    const monthlyDisplay = document.getElementById('monthlyDisplay');
    const monthsDisplay = document.getElementById('monthsDisplay');
    const aiFeedback = document.getElementById('aiFeedback');
    const riskBadge = document.getElementById('riskBadge');
    
    const ctx = document.getElementById('debtChart').getContext('2d');
    let debtChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: [],
            datasets: [{
                label: 'Remaining Debt (TND)',
                data: [],
                borderColor: '#0d6efd',
                backgroundColor: 'rgba(13, 110, 253, 0.1)',
                fill: true,
                tension: 0.4
            }]
        },
        options: { 
            responsive: true, 
            maintainAspectRatio: false,
            scales: { y: { beginAtZero: true } } 
        }
    });

    function updateSimulator() {
        const val = slider.value;
        monthlyDisplay.innerText = val;

        fetch("{{ path('loan_simulate') }}", {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                remaining: {{ loan.amount - totalPaid }},
                monthly_payment: val
            })
        })
        .then(res => res.json())
        .then(data => {
            monthsDisplay.innerText = data.months_needed;
            aiFeedback.innerText = data.ai_message;
            riskBadge.innerText = data.risk;
            riskBadge.className = 'badge bg-' + data.risk_color;

            const labels = data.timeline.map(t => t.month);
            const points = data.timeline.map(t => t.balance);
            
            debtChart.data.labels = labels;
            debtChart.data.datasets[0].data = points;
            debtChart.update();
        });
    }

    slider.addEventListener('input', updateSimulator);
    updateSimulator();
});
</script>
{% endblock %}