{% extends 'base.html.twig' %}

{% block title %}Add Repayment{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h4>Add Repayment for Loan #{{ loan.id }}</h4>
        </div>
        <div class="card-body">
            <form method="post">
                <div class="mb-3">
                    <label>Amount (TND)</label>
                    <input type="number" step="0.01" name="amount" class="form-control" required>
                </div>
                
                <div class="mb-3">
                    <label>Payment Date</label>
                    <input type="date" name="payment_date" class="form-control" value="{{ 'now'|date('Y-m-d') }}" required>
                </div>
                
                <div class="mb-3">
                    <label>Payment Type</label>
                    <select name="payment_type" class="form-control">
                        <option value="monthly">Monthly Payment</option>
                        <option value="extra">Extra Payment</option>
                        <option value="full">Full Payment</option>
                    </select>
                </div>
                
                <button type="submit" class="btn btn-primary">Save Repayment</button>
                <a href="{{ path('loan_show', {id: loan.id}) }}" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
{% endblock %}