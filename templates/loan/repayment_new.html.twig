{% extends 'base.html.twig' %}

{% block title %}Add Repayment — Loan #{{ loan.id }}{% endblock %}
{% block page_title %}Add Repayment — Loan #{{ loan.id }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header">
                <h3 class="card-title"><i class="bi bi-calendar-plus me-2"></i>Record a Repayment</h3>
            </div>
            <div class="card-body">
                <div class="alert alert-info mb-4">
                    Loan amount: <strong>{{ loan.amount|number_format(2, '.', ',') }} TND</strong> |
                    Status: <strong>{{ loan.status|capitalize }}</strong>
                </div>

                <form method="post" action="{{ path('loan_repayment_new', {id: loan.id}) }}">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Amount Paid (TND)</label>
                        <input type="number" step="0.01" min="0.01" name="amount" class="form-control" required placeholder="e.g. 500.00">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Payment Date</label>
                        <input type="date" name="payment_date" class="form-control" required value="{{ "now"|date('Y-m-d') }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Payment Type</label>
                        <select name="payment_type" class="form-select">
                            <option value="">— Select type —</option>
                            <option value="bank_transfer">Bank Transfer</option>
                            <option value="cash">Cash</option>
                            <option value="cheque">Cheque</option>
                            <option value="direct_debit">Direct Debit</option>
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Monthly Payment Amount (optional)</label>
                        <input type="number" step="0.01" min="0" name="monthly_payment" class="form-control" placeholder="e.g. 500.00">
                        <small class="text-muted">Leave blank if this is a one-time payment.</small>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Save Repayment
                        </button>
                        <a href="{{ path('loan_show', {id: loan.id}) }}" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
