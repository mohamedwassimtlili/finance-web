{% extends 'base.html.twig' %}

{% block title %}My Bills{% endblock %}
{% block page_title %}All My Bills{% endblock %}

{% block body %}
{% for msg in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

<div class="card shadow-sm">
    <div class="card-header">
        <h3 class="card-title"><i class="bi bi-file-earmark-text me-2"></i>Bill List</h3>
        <span class="badge bg-secondary ms-2">{{ bills|length }} total</span>
    </div>
    <div class="card-body p-0">
        {% if bills is empty %}
            <div class="text-center py-5 text-muted">
                <i class="bi bi-file-earmark-x" style="font-size:3rem;"></i>
                <p class="mt-2">No bills yet. Add them from inside a budget.</p>
                <a href="{{ path('finance_budgets') }}" class="btn btn-outline-primary btn-sm">My Budgets</a>
            </div>
        {% else %}
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>#</th><th>Name</th><th>Budget</th><th>Amount (TND)</th><th>Due Day</th><th>Frequency</th><th>Category</th><th>Status</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                {% for bill in bills %}
                    <tr>
                        <td>{{ bill.id }}</td>
                        <td>{{ bill.name }}</td>
                        <td>
                            <a href="{{ path('finance_budget_show', {id: bill.budget.id}) }}" class="text-decoration-none">
                                {{ bill.budget.name }}
                            </a>
                        </td>
                        <td>{{ bill.amount|number_format(2,'.', ',') }}</td>
                        <td>Day {{ bill.dueDay }}</td>
                        <td>{{ bill.frequency|capitalize }}</td>
                        <td>{{ bill.category|default('—') }}</td>
                        <td>
                            {% if bill.status == 'PAID' %}<span class="badge bg-success">Paid</span>
                            {% else %}<span class="badge bg-warning text-dark">Unpaid</span>{% endif %}
                        </td>
                        <td class="text-end">
                            {% if bill.status != 'PAID' %}
                                <form method="post" action="{{ path('finance_bill_pay', {id: bill.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('pay_bill_' ~ bill.id) }}">
                                    <button class="btn btn-sm btn-success" title="Mark paid"><i class="bi bi-check-circle"></i></button>
                                </form>
                            {% endif %}
                            <a href="{{ path('finance_bill_edit', {id: bill.id}) }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                            <form method="post" action="{{ path('finance_bill_delete', {id: bill.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Delete this bill?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_bill_' ~ bill.id) }}">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}
