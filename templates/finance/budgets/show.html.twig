{% extends 'base.html.twig' %}

{% block title %}{{ budget.name }}{% endblock %}
{% block page_title %}Budget — {{ budget.name }}{% endblock %}

{% block body %}
{% for msg in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

{# Summary row #}
<div class="row mb-4 g-3">
    <div class="col-md-4">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h6 class="text-muted">Total Budget</h6>
                <h3 class="text-primary">{{ budget.amount|number_format(2,'.', ',') }} TND</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h6 class="text-muted">Spent</h6>
                <h3 class="text-danger">{{ budget.spentAmount|number_format(2,'.', ',') }} TND</h3>
                <small class="text-muted">Expenses: {{ totalExpenses|number_format(2,'.', ',') }} | Bills: {{ totalBills|number_format(2,'.', ',') }}</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h6 class="text-muted">Remaining</h6>
                {% set remaining = budget.amount - budget.spentAmount %}
                <h3 class="{{ remaining >= 0 ? 'text-success' : 'text-danger' }}">{{ remaining|number_format(2,'.', ',') }} TND</h3>
                {% set pct = budget.amount > 0 ? (budget.spentAmount / budget.amount * 100)|round : 0 %}
                <div class="progress mt-2" style="height:10px;">
                    <div class="progress-bar {% if pct >= 100 %}bg-danger{% elseif pct >= 75 %}bg-warning{% else %}bg-success{% endif %}"
                         style="width:{{ pct > 100 ? 100 : pct }}%"></div>
                </div>
                <small class="text-muted">{{ pct }}% used</small>
            </div>
        </div>
    </div>
</div>

{# Expenses #}
<div class="card shadow-sm mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0"><i class="bi bi-receipt me-2"></i>Expenses</h3>
        <a href="{{ path('finance_expense_new', {id: budget.id}) }}" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add Expense
        </a>
    </div>
    <div class="card-body p-0">
        {% if budget.expenses is empty %}
            <p class="text-center text-muted py-4">No expenses yet.</p>
        {% else %}
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Amount</th><th>Category</th><th>Date</th><th>Description</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                {% for e in budget.expenses %}
                    <tr>
                        <td>{{ e.amount|number_format(2,'.', ',') }} TND</td>
                        <td>{{ e.category|default('—') }}</td>
                        <td>{{ e.expenseDate|date('d/m/Y') }}</td>
                        <td>{{ e.description|default('—')|slice(0,40) }}</td>
                        <td class="text-end">
                            <a href="{{ path('finance_expense_edit', {id: e.id}) }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                            <form method="post" action="{{ path('finance_expense_delete', {id: e.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Delete this expense?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_expense_' ~ e.id) }}">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>

{# Bills #}
<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0"><i class="bi bi-file-earmark-text me-2"></i>Bills</h3>
        <a href="{{ path('finance_bill_new', {id: budget.id}) }}" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add Bill
        </a>
    </div>
    <div class="card-body p-0">
        {% if budget.bills is empty %}
            <p class="text-center text-muted py-4">No bills yet.</p>
        {% else %}
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Name</th><th>Amount</th><th>Due Day</th><th>Frequency</th><th>Status</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                {% for bill in budget.bills %}
                    <tr>
                        <td>{{ bill.name }}</td>
                        <td>{{ bill.amount|number_format(2,'.', ',') }} TND</td>
                        <td>Day {{ bill.dueDay }}</td>
                        <td>{{ bill.frequency|capitalize }}</td>
                        <td>
                            {% if bill.status == 'PAID' %}<span class="badge bg-success">Paid</span>
                            {% else %}<span class="badge bg-warning text-dark">Unpaid</span>{% endif %}
                        </td>
                        <td class="text-end">
                            {% if bill.status != 'PAID' %}
                                <form method="post" action="{{ path('finance_bill_pay', {id: bill.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('pay_bill_' ~ bill.id) }}">
                                    <button class="btn btn-sm btn-success" onclick="return confirm('Mark as paid?')"><i class="bi bi-check-circle"></i></button>
                                </form>
                            {% endif %}
                            <a href="{{ path('finance_bill_edit', {id: bill.id}) }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                            <form method="post" action="{{ path('finance_bill_delete', {id: bill.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Delete this bill?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_bill_' ~ bill.id) }}">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a href="{{ path('finance_budgets') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
    <a href="{{ path('finance_budget_edit', {id: budget.id}) }}" class="btn btn-outline-primary"><i class="bi bi-pencil me-1"></i>Edit Budget</a>
</div>
{% endblock %}
