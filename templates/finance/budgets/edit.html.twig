{% extends 'base.html.twig' %}

{% block title %}Edit Budget{% endblock %}
{% block page_title %}Edit Budget — {{ budget.name }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header"><h3 class="card-title"><i class="bi bi-pencil me-2"></i>Edit Budget</h3></div>
            <div class="card-body">
                <form method="post" action="{{ path('finance_budget_edit', {id: budget.id}) }}">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Budget Name</label>
                        <input type="text" name="name" class="form-control" required value="{{ budget.name }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Total Amount (TND)</label>
                        <input type="number" step="0.01" min="0.01" name="amount" class="form-control" required value="{{ budget.amount }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Category</label>
                        <select name="category" class="form-select">
                            <option value="">— None —</option>
                            {% for cat in ['Food','Transport','Health','Housing','Education','Entertainment','Other'] %}
                                <option {% if budget.category == cat %}selected{% endif %}>{{ cat }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Start Date</label>
                            <input type="date" name="start_date" class="form-control" required value="{{ budget.startDate|date('Y-m-d') }}">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">End Date</label>
                            <input type="date" name="end_date" class="form-control" required value="{{ budget.endDate|date('Y-m-d') }}">
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save Changes</button>
                        <a href="{{ path('finance_budget_show', {id: budget.id}) }}" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
