{% extends 'base.html.twig' %}

{% block title %}My Budgets{% endblock %}
{% block page_title %}My Budgets{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">Track and manage your personal budgets.</p>
    <a href="{{ path('finance_budget_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> New Budget
    </a>
</div>

{% for msg in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

{% if budgets is empty %}
    <div class="text-center py-5 text-muted">
        <i class="bi bi-wallet2" style="font-size:3rem;"></i>
        <p class="mt-2">No budgets yet. Create your first one!</p>
    </div>
{% else %}
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        {% for b in budgets %}
        {% set pct = b.amount > 0 ? (b.spentAmount / b.amount * 100)|round : 0 %}
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>{{ b.name }}</strong>
                    {% if b.category %}<span class="badge bg-secondary">{{ b.category }}</span>{% endif %}
                </div>
                <div class="card-body">
                    <p class="mb-1 text-muted small">{{ b.startDate|date('d/m/Y') }} → {{ b.endDate|date('d/m/Y') }}</p>
                    <h5 class="mb-0">{{ b.amount|number_format(2,'.', ',') }} TND</h5>
                    <small class="text-muted">Spent: {{ b.spentAmount|number_format(2,'.', ',') }} TND</small>
                    <div class="progress mt-2" style="height:10px;">
                        <div class="progress-bar {% if pct >= 100 %}bg-danger{% elseif pct >= 75 %}bg-warning{% else %}bg-success{% endif %}"
                             role="progressbar" style="width:{{ pct > 100 ? 100 : pct }}%"></div>
                    </div>
                    <small class="text-muted">{{ pct }}% used</small>
                </div>
                <div class="card-footer d-flex gap-2">
                    <a href="{{ path('finance_budget_show', {id: b.id}) }}" class="btn btn-sm btn-outline-primary flex-fill">
                        <i class="bi bi-eye"></i> View
                    </a>
                    <a href="{{ path('finance_budget_edit', {id: b.id}) }}" class="btn btn-sm btn-outline-secondary flex-fill">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <form method="post" action="{{ path('finance_budget_delete', {id: b.id}) }}" class="d-inline flex-fill"
                          onsubmit="return confirm('Delete this budget?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_budget_' ~ b.id) }}">
                        <button class="btn btn-sm btn-outline-danger w-100"><i class="bi bi-trash"></i> Delete</button>
                    </form>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
