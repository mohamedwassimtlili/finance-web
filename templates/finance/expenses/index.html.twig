{% extends 'base.html.twig' %}

{% block title %}All My Expenses{% endblock %}
{% block page_title %}All My Expenses{% endblock %}

{% block body %}
{% for msg in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

<div class="card shadow-sm">
    <div class="card-header">
        <h3 class="card-title"><i class="bi bi-receipt me-2"></i>Expense History</h3>
        <span class="badge bg-secondary ms-2">{{ expenses|length }} total</span>
    </div>
    <div class="card-body p-0">
        {% if expenses is empty %}
            <div class="text-center py-5 text-muted">
                <i class="bi bi-receipt-cutoff" style="font-size:3rem;"></i>
                <p class="mt-2">No expenses recorded yet. Go to a budget to add one.</p>
                <a href="{{ path('finance_budgets') }}" class="btn btn-outline-primary btn-sm">My Budgets</a>
            </div>
        {% else %}
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>#</th><th>Budget</th><th>Amount (TND)</th><th>Category</th><th>Date</th><th>Description</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                {% for e in expenses %}
                    <tr>
                        <td>{{ e.id }}</td>
                        <td>
                            <a href="{{ path('finance_budget_show', {id: e.budget.id}) }}" class="text-decoration-none">
                                {{ e.budget.name }}
                            </a>
                        </td>
                        <td>{{ e.amount|number_format(2,'.', ',') }}</td>
                        <td>{{ e.category|default('—') }}</td>
                        <td>{{ e.expenseDate|date('d/m/Y') }}</td>
                        <td>{{ e.description|default('—')|slice(0,50) }}</td>
                        <td class="text-end">
                            <a href="{{ path('finance_expense_edit', {id: e.id}) }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                            <form method="post" action="{{ path('finance_expense_delete', {id: e.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Delete this expense?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_expense_' ~ e.id) }}">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}
