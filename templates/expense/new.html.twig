{% extends 'base.html.twig' %}
{% block title %}New Expense{% endblock %}
{% block body %}
<div class="container py-4" style="max-width: 600px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">💸 Add New Expense</h3>
        <a href="{{ path('finance_expenses') }}" class="btn btn-outline-secondary btn-sm">← Back</a>
    </div>

    {# ── Receipt Scanner Card ─────────────────────────── #}
    <div class="card border-0 shadow-sm mb-3" style="border-radius:12px; overflow:hidden;">
        <div style="padding:1rem 1.5rem; border-bottom:1px solid #f0f2f5; background:#f8f9fc;">
            <span style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.8px; color:#8a94a6;">
                📷 Receipt Scanner (OCR)
            </span>
        </div>
        <div class="card-body p-4">
            <p style="font-size:0.82rem; color:#8a94a6; margin-bottom:1rem;">
                Upload a photo of your receipt and we'll automatically fill in the form for you.
            </p>
            <div style="
                border: 2px dashed #e2e8f0;
                border-radius: 10px;
                padding: 2rem;
                text-align: center;
                background: #fafbfd;
                cursor: pointer;
                transition: border-color 0.2s;
            " id="dropZone" onclick="document.getElementById('receiptFile').click()">
                <div style="font-size:2rem; margin-bottom:0.5rem;">📄</div>
                <div style="font-size:0.82rem; font-weight:600; color:#1a1f36;">Click to upload receipt</div>
                <div style="font-size:0.72rem; color:#8a94a6; margin-top:4px;">JPG, PNG, PDF supported</div>
                <input type="file" id="receiptFile" accept="image/*,.pdf" style="display:none;">
            </div>

            {# Preview #}
            <div id="previewBox" style="display:none; margin-top:1rem; text-align:center;">
                <img id="previewImg" src="" style="max-width:100%; max-height:200px; border-radius:8px; border:1px solid #f0f2f5;">
            </div>

            {# Scan button #}
            <button type="button" id="scanBtn" onclick="scanReceipt()"
                style="display:none; width:100%; margin-top:1rem;"
                class="btn btn-dark btn-sm">
                🔍 Scan Receipt
            </button>

            {# Loading #}
            <div id="scanLoading" style="display:none; text-align:center; margin-top:1rem;">
                <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                <span style="font-size:0.82rem; color:#8a94a6; margin-left:0.5rem;">Reading receipt...</span>
            </div>

            {# Result #}
            <div id="scanResult" style="display:none; margin-top:1rem; padding:0.75rem 1rem; background:#f0fdf4; border-radius:8px; border-left:3px solid #16a34a;">
                <span style="font-size:0.78rem; font-weight:600; color:#15803d;">✅ Receipt scanned! Form filled automatically.</span>
            </div>

            {# Error #}
            <div id="scanError" style="display:none; margin-top:1rem; padding:0.75rem 1rem; background:#fef2f2; border-radius:8px; border-left:3px solid #e74c3c;">
                <span style="font-size:0.78rem; font-weight:600; color:#b91c1c;" id="scanErrorMsg"></span>
            </div>
        </div>
    </div>

    {# ── Expense Form ─────────────────────────────────── #}
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-body p-4">
            <form method="post" id="expenseForm">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Linked Budget <span class="text-danger">*</span></label>
                    <select name="budget_id" class="form-select" required>
                        <option value="">-- Select a budget --</option>
                        {% for budget in budgets %}
                            <option value="{{ budget.id }}"
                                {{ budget.id == preselectedBudget ? 'selected' : '' }}>
                                {{ budget.name }} ({{ budget.amount|number_format(2) }} TND)
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Amount (TND) <span class="text-danger">*</span></label>
                    <input type="number" name="amount" id="amountField"
                           step="0.01" min="0.01" max="999999.99"
                           class="form-control" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Category</label>
                    <select name="category" id="categoryField" class="form-select">
                        <option value="">-- Select a category --</option>
                        <option value="Food & Dining">🍽️ Food & Dining</option>
                        <option value="Housing & Rent">🏠 Housing & Rent</option>
                        <option value="Transport">🚗 Transport</option>
                        <option value="Healthcare">🏥 Healthcare</option>
                        <option value="Entertainment">🎬 Entertainment</option>
                        <option value="Education">📚 Education</option>
                        <option value="Utilities">💡 Utilities</option>
                        <option value="Other">📦 Other</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Date <span class="text-danger">*</span></label>
                    <input type="date" name="expense_date" id="dateField"
                           class="form-control"
                           max="{{ 'now'|date('Y-m-d') }}" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea name="description" id="descriptionField"
                              class="form-control" rows="2" maxlength="500"></textarea>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary px-4">Add Expense</button>
                    <a href="{{ path('finance_expenses') }}" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
const OCR_API_KEY = 'K89873651388957';

// ── File selection & preview ──────────────────────────
document.getElementById('receiptFile').addEventListener('change', function() {
    const file = this.files[0];
    if (!file) return;

    // show preview
    if (file.type.startsWith('image/')) {
        const reader = new FileReader();
        reader.onload = function(e) {
            document.getElementById('previewImg').src = e.target.result;
            document.getElementById('previewBox').style.display = 'block';
        };
        reader.readAsDataURL(file);
    }

    // show scan button
    document.getElementById('scanBtn').style.display = 'block';
    document.getElementById('scanResult').style.display = 'none';
    document.getElementById('scanError').style.display = 'none';

    // highlight drop zone
    document.getElementById('dropZone').style.borderColor = '#1a1f36';
});

// ── Scan receipt ──────────────────────────────────────
async function scanReceipt() {
    const file = document.getElementById('receiptFile').files[0];
    if (!file) return;

    // show loading
    document.getElementById('scanLoading').style.display = 'block';
    document.getElementById('scanBtn').style.display = 'none';
    document.getElementById('scanResult').style.display = 'none';
    document.getElementById('scanError').style.display = 'none';

    try {
        const formData = new FormData();
        formData.append('file', file);
        formData.append('apikey', OCR_API_KEY);
        formData.append('language', 'eng');
        formData.append('isOverlayRequired', 'false');

        const response = await fetch('https://api.ocr.space/parse/image', {
            method: 'POST',
            body: formData
        });

        const data = await response.json();

        if (data.IsErroredOnProcessing) {
            throw new Error(data.ErrorMessage || 'OCR processing failed');
        }

        const text = data.ParsedResults[0].ParsedText;
        console.log('OCR Text:', text); // for debugging

        parseReceiptText(text);

        document.getElementById('scanLoading').style.display = 'none';
        document.getElementById('scanResult').style.display = 'block';

    } catch (err) {
        document.getElementById('scanLoading').style.display = 'none';
        document.getElementById('scanError').style.display = 'block';
        document.getElementById('scanErrorMsg').textContent = '❌ ' + (err.message || 'Could not read receipt. Please fill manually.');
        document.getElementById('scanBtn').style.display = 'block';
    }
}

// ── Parse OCR text and fill form ──────────────────────
function parseReceiptText(text) {
    const lines = text.split('\n').map(l => l.trim()).filter(l => l.length > 0);

    // ── Amount: look for total/montant/amount + number ──
    let amount = null;
    const amountPatterns = [
        /total[^\d]*(\d+[.,]\d{1,2})/i,
        /montant[^\d]*(\d+[.,]\d{1,2})/i,
        /amount[^\d]*(\d+[.,]\d{1,2})/i,
        /net[^\d]*(\d+[.,]\d{1,2})/i,
        /ttc[^\d]*(\d+[.,]\d{1,2})/i,
        /(\d+[.,]\d{2})\s*(tnd|dt|dinar)?$/im,
    ];
    for (const pattern of amountPatterns) {
        const match = text.match(pattern);
        if (match) {
            amount = parseFloat(match[1].replace(',', '.'));
            break;
        }
    }
    // fallback: find largest number in text
    if (!amount) {
        const allNumbers = [...text.matchAll(/(\d+[.,]\d{2})/g)]
            .map(m => parseFloat(m[1].replace(',', '.')));
        if (allNumbers.length > 0) {
            amount = Math.max(...allNumbers);
        }
    }
    if (amount) {
        document.getElementById('amountField').value = amount.toFixed(2);
    }

    // ── Date: look for common date formats ──────────────
    const datePatterns = [
        /(\d{2})[\/\-\.](\d{2})[\/\-\.](\d{4})/,  // dd/mm/yyyy
        /(\d{4})[\/\-\.](\d{2})[\/\-\.](\d{2})/,  // yyyy-mm-dd
        /(\d{2})[\/\-\.](\d{2})[\/\-\.](\d{2})/,  // dd/mm/yy
    ];
    for (const pattern of datePatterns) {
        const match = text.match(pattern);
        if (match) {
            let year, month, day;
            if (match[1].length === 4) {
                [, year, month, day] = match;
            } else if (parseInt(match[3]) > 31) {
                [, day, month, year] = match;
            } else {
                [, day, month, year] = match;
                if (year.length === 2) year = '20' + year;
            }
            const dateStr = `${year}-${month.padStart(2,'0')}-${day.padStart(2,'0')}`;
            const today = new Date().toISOString().split('T')[0];
            if (dateStr <= today) {
                document.getElementById('dateField').value = dateStr;
            }
            break;
        }
    }

    // ── Category: keyword detection ──────────────────────
    const textLower = text.toLowerCase();
    const categoryMap = {
        'Food & Dining':  ['restaurant', 'cafe', 'coffee', 'food', 'pizza', 'burger', 'meal', 'breakfast', 'lunch', 'dinner', 'snack', 'supermarket', 'grocery', 'carrefour', 'monoprix'],
        'Transport':      ['taxi', 'uber', 'fuel', 'petrol', 'essence', 'parking', 'bus', 'metro', 'train', 'transport', 'autoroute'],
        'Healthcare':     ['pharmacy', 'pharmacie', 'doctor', 'clinic', 'hospital', 'medical', 'medicament'],
        'Utilities':      ['electric', 'electricity', 'water', 'internet', 'phone', 'steg', 'sonede', 'telecom'],
        'Entertainment':  ['cinema', 'movie', 'theatre', 'concert', 'sport', 'gym', 'netflix'],
        'Education':      ['school', 'university', 'book', 'course', 'formation', 'library'],
        'Housing & Rent': ['rent', 'loyer', 'apartment', 'housing', 'maintenance'],
    };
    for (const [category, keywords] of Object.entries(categoryMap)) {
        if (keywords.some(kw => textLower.includes(kw))) {
            document.getElementById('categoryField').value = category;
            break;
        }
    }

    // ── Description: use first meaningful line ───────────
    const firstLine = lines.find(l => l.length > 3 && !/^\d+$/.test(l));
    if (firstLine) {
        document.getElementById('descriptionField').value = firstLine.substring(0, 100);
    }
}
</script>
{% endblock %}