{% extends 'base.html.twig' %}
{% block title %}Edit Expense{% endblock %}
{% block body %}
<div class="container py-4" style="max-width: 600px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">✏️ Edit Expense</h3>
        <a href="{{ path('finance_expenses') }}" class="btn btn-outline-secondary btn-sm">← Back</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form method="post">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Amount (TND) <span class="text-danger">*</span></label>
                    <input type="number" name="amount" step="0.01" min="0.01" max="999999.99"
                           class="form-control" value="{{ expense.amount }}" required>
                </div>
                <div class="mb-3">
    <label class="form-label fw-semibold">Category</label>
    <select name="category" class="form-select">
        <option value="">-- Select a category --</option>
        <option value="Food & Dining"    {{ expense.category == 'Food & Dining'    ? 'selected' : '' }}>🍽️ Food & Dining</option>
        <option value="Housing & Rent"   {{ expense.category == 'Housing & Rent'   ? 'selected' : '' }}>🏠 Housing & Rent</option>
        <option value="Transport"        {{ expense.category == 'Transport'        ? 'selected' : '' }}>🚗 Transport</option>
        <option value="Healthcare"       {{ expense.category == 'Healthcare'       ? 'selected' : '' }}>🏥 Healthcare</option>
        <option value="Entertainment"    {{ expense.category == 'Entertainment'    ? 'selected' : '' }}>🎬 Entertainment</option>
        <option value="Education"        {{ expense.category == 'Education'        ? 'selected' : '' }}>📚 Education</option>
        <option value="Utilities"        {{ expense.category == 'Utilities'        ? 'selected' : '' }}>💡 Utilities</option>
        <option value="Other"            {{ expense.category == 'Other'            ? 'selected' : '' }}>📦 Other</option>
    </select>
</div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Date <span class="text-danger">*</span></label>
                    <input type="date" name="expense_date" class="form-control"
                           value="{{ expense.expenseDate|date('Y-m-d') }}"
                           max="{{ 'now'|date('Y-m-d') }}" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea name="description" class="form-control" rows="2" maxlength="500">{{ expense.description }}</textarea>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                    <a href="{{ path('finance_expenses') }}" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}