<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password — FinanceApp</title>
    <link rel="stylesheet" href="{{ asset('adminlte/css/adminlte.min.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="login-page bg-body-secondary">
    <div class="login-box">
        <div class="login-logo text-center py-4">
            <a href="{{ path('app_login') }}"><b>Finance</b>App</a>
        </div>
        <div class="card card-outline card-success">
            <div class="card-body login-card-body">
                <p class="login-box-msg">
                    <i class="bi bi-shield-lock-fill me-1"></i>
                    Enter the 6-digit code from your email and choose a new password.
                </p>

                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }}">{{ message }}</div>
                    {% endfor %}
                {% endfor %}

                <form method="post" id="resetForm">
                    <div class="input-group mb-3">
                        <div class="form-floating flex-grow-1">
                            <input type="text" name="code" id="inputCode"
                                   class="form-control text-center fw-bold fs-4 letter-spacing-4"
                                   placeholder="000000" maxlength="6"
                                   pattern="\d{6}" required autofocus
                                   style="letter-spacing: 8px;">
                            <label for="inputCode">6-Digit Code</label>
                        </div>
                        <div class="input-group-text">
                            <span class="bi bi-hash"></span>
                        </div>
                    </div>

                    <div class="input-group mb-3">
                        <div class="form-floating flex-grow-1">
                            <input type="password" name="password" id="inputPassword"
                                   class="form-control" placeholder="New Password"
                                   minlength="8" required>
                            <label for="inputPassword">New Password</label>
                        </div>
                        <div class="input-group-text">
                            <span class="bi bi-lock-fill"></span>
                        </div>
                    </div>

                    <div class="input-group mb-4">
                        <div class="form-floating flex-grow-1">
                            <input type="password" name="confirm" id="inputConfirm"
                                   class="form-control" placeholder="Confirm Password"
                                   minlength="8" required>
                            <label for="inputConfirm">Confirm New Password</label>
                        </div>
                        <div class="input-group-text">
                            <span class="bi bi-lock-fill"></span>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i> Reset Password
                        </button>
                    </div>
                </form>

                <p class="mt-3 mb-0 text-center">
                    <a href="{{ path('app_forgot_password') }}">
                        <i class="bi bi-arrow-left me-1"></i>Request a new code
                    </a>
                </p>
            </div>
        </div>
    </div>

    <script src="{{ asset('adminlte/js/adminlte.min.js') }}"></script>
    <script>
        // Client-side password match validation
        document.getElementById('resetForm').addEventListener('submit', function (e) {
            const pw  = document.getElementById('inputPassword').value;
            const con = document.getElementById('inputConfirm').value;
            if (pw !== con) {
                e.preventDefault();
                alert('Passwords do not match.');
            }
        });
    </script>
</body>
</html>
