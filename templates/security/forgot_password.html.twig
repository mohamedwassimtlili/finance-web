<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password — FinanceApp</title>
    <link rel="stylesheet" href="{{ asset('adminlte/css/adminlte.min.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="login-page bg-body-secondary">
    <div class="login-box">
        <div class="login-logo text-center py-4">
            <a href="{{ path('app_login') }}"><b>Finance</b>App</a>
        </div>
        <div class="card card-outline card-warning">
            <div class="card-body login-card-body">
                <p class="login-box-msg">
                    <i class="bi bi-key-fill me-1"></i>
                    Enter your email address and we'll send you a 6-digit reset code.
                </p>

                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }}">{{ message }}</div>
                    {% endfor %}
                {% endfor %}

                <form method="post">
                    <div class="input-group mb-3">
                        <div class="form-floating flex-grow-1">
                            <input type="email" name="email" id="inputEmail"
                                   class="form-control" placeholder="Email" required autofocus>
                            <label for="inputEmail">Your Email Address</label>
                        </div>
                        <div class="input-group-text">
                            <span class="bi bi-envelope"></span>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-send me-1"></i> Send Reset Code
                        </button>
                    </div>
                </form>

                <p class="mt-3 mb-0 text-center">
                    <a href="{{ path('app_login') }}"><i class="bi bi-arrow-left me-1"></i>Back to Sign In</a>
                </p>
                <p class="mt-1 mb-0 text-center">
                    Already have a code? <a href="{{ path('app_reset_password') }}">Enter it here</a>
                </p>
            </div>
        </div>
    </div>
    <script src="{{ asset('adminlte/js/adminlte.min.js') }}"></script>
</body>
</html>
