<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Email — FinanceApp</title>
    <link rel="stylesheet" href="{{ asset('adminlte/css/adminlte.min.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="login-page bg-body-secondary">
    <div class="login-box">
        <div class="login-logo text-center py-4">
            <a href="#"><b>Finance</b>App</a>
        </div>
        <div class="card card-outline card-success">
            <div class="card-body login-card-body">
                <p class="login-box-msg">
                    <i class="bi bi-envelope-check-fill me-1"></i>
                    A 6-digit code was sent to <strong>{{ email }}</strong>
                </p>

                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }}">{{ message }}</div>
                    {% endfor %}
                {% endfor %}

                {% if error %}
                    <div class="alert alert-danger">{{ error }}</div>
                {% endif %}

                <!-- Verify form -->
                <form method="post">
                    <div class="input-group mb-3">
                        <div class="form-floating flex-grow-1">
                            <input type="text" name="code" id="inputCode"
                                   class="form-control text-center fw-bold fs-4"
                                   placeholder="000000" maxlength="6"
                                   pattern="\d{6}" required autofocus
                                   style="letter-spacing:8px;">
                            <label for="inputCode">6-Digit Code</label>
                        </div>
                        <div class="input-group-text">
                            <span class="bi bi-hash"></span>
                        </div>
                    </div>
                    <div class="d-grid gap-2 mb-3">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i> Verify Email
                        </button>
                    </div>
                </form>

                <!-- Resend form -->
                <form method="post">
                    <div class="d-grid">
                        <button type="submit" name="resend" value="1" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-arrow-repeat me-1"></i> Resend code
                        </button>
                    </div>
                </form>

                <p class="mt-3 text-center">
                    <a href="{{ path('app_login') }}">Back to login</a>
                </p>
            </div>
        </div>
    </div>
    <script src="{{ asset('adminlte/js/adminlte.min.js') }}"></script>
</body>
</html>