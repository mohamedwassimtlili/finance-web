{% extends 'base.html.twig' %}

{% block title %}Bill Management{% endblock %}

{% block body %}
<div class="container py-4">
{# ── Page Header ─────────────────────────────────────────── #}
<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h2 class="fw-semibold mb-1" style="color: #1a1f36;">Bills Management</h2>
        <p class="text-muted small mb-0">Track and manage your recurring payments</p>
    </div>
    <div class="d-flex gap-2 align-items-center">

        {# ── Notification Bell ─────────────────────── #}
        {% set currentDay = 'now'|date('j') %}
        {% set notifList = [] %}

        {% for bill in bills %}
            {% if bill.status == 'UNPAID' %}
                {% set daysUntilDue = bill.dueDay - currentDay %}
                {% if daysUntilDue < 0 %}
                    {% set notifList = notifList|merge([{
                        'type': 'danger',
                        'icon': '🔴',
                        'message': '"' ~ bill.name ~ '" of ' ~ bill.amount|number_format(2) ~ ' TND was due on day ' ~ bill.dueDay
                    }]) %}
                {% elseif daysUntilDue <= 3 %}
                    {% set notifList = notifList|merge([{
                        'type': 'warning',
                        'icon': '🟠',
                        'message': '"' ~ bill.name ~ '" of ' ~ bill.amount|number_format(2) ~ ' TND is due in ' ~ daysUntilDue ~ ' day(s)'
                    }]) %}
                {% elseif daysUntilDue <= 7 %}
                    {% set notifList = notifList|merge([{
                        'type': 'info',
                        'icon': '🟡',
                        'message': '"' ~ bill.name ~ '" of ' ~ bill.amount|number_format(2) ~ ' TND is due in ' ~ daysUntilDue ~ ' days'
                    }]) %}
                {% endif %}
            {% endif %}
        {% endfor %}

        {% if notifList|length == 0 %}
            {% set notifList = notifList|merge([{
                'type': 'success',
                'icon': '🟢',
                'message': 'No upcoming bill reminders!'
            }]) %}
        {% endif %}

        <div class="position-relative" id="notifWrapper">
            <button onclick="toggleNotif()" class="btn btn-outline-secondary btn-sm position-relative" style="font-size:1.1rem; padding: 0.3rem 0.65rem; border-radius:8px;">
                🔔
                {% set urgentCount = 0 %}
                {% for n in notifList %}
                    {% if n.type == 'danger' or n.type == 'warning' %}
                        {% set urgentCount = urgentCount + 1 %}
                    {% endif %}
                {% endfor %}
                {% if urgentCount > 0 %}
                    <span style="
                        position: absolute;
                        top: -5px; right: -5px;
                        background: #e74c3c;
                        color: white;
                        font-size: 0.6rem;
                        font-weight: 700;
                        width: 16px; height: 16px;
                        border-radius: 50%;
                        display: flex; align-items: center; justify-content: center;
                    ">{{ urgentCount }}</span>
                {% endif %}
            </button>

            {# Dropdown #}
            <div id="notifDropdown" style="
                display: none;
                position: absolute;
                right: 0; top: calc(100% + 8px);
                width: 320px;
                background: #fff;
                border-radius: 12px;
                box-shadow: 0 8px 24px rgba(0,0,0,0.12);
                z-index: 9999;
                overflow: hidden;
            ">
                <div style="padding: 0.85rem 1rem; border-bottom: 1px solid #f0f2f5; display:flex; justify-content:space-between; align-items:center;">
                    <span style="font-size:0.78rem; font-weight:700; text-transform:uppercase; letter-spacing:0.6px; color:#8a94a6;">Bill Reminders</span>
                    <span style="font-size:0.72rem; color:#8a94a6;">{{ notifList|length }} alert{{ notifList|length != 1 ? 's' : '' }}</span>
                </div>
                {% for notif in notifList %}
                    <div style="
                        padding: 0.85rem 1rem;
                        border-bottom: 1px solid #f8f9fc;
                        display: flex;
                        align-items: flex-start;
                        gap: 0.6rem;
                        {% if notif.type == 'danger' %}background: #fff8f8;
                        {% elseif notif.type == 'warning' %}background: #fffdf5;
                        {% elseif notif.type == 'info' %}background: #f8fbff;
                        {% else %}background: #f6fef9;{% endif %}
                    ">
                        <span style="font-size:0.9rem; margin-top:1px;">{{ notif.icon }}</span>
                        <span style="font-size:0.82rem; color:#1a1f36; line-height:1.4;">{{ notif.message }}</span>
                    </div>
                {% endfor %}
                <div style="padding: 0.6rem 1rem; text-align:center;">
                    <small style="color:#8a94a6; font-size:0.72rem;">Click anywhere to close</small>
                </div>
            </div>
        </div>
        {# ── End Bell ──────────────────────────────── #}

        <a href="{{ path('finance_budgets') }}" class="btn btn-outline-secondary btn-sm">← Budgets</a>
        <a href="{{ path('finance_bill_new') }}" class="btn btn-dark btn-sm">+ New Bill</a>
    </div>
</div>

    {# ── Statistics Summary ───────────────────────────────────── #}
    {% set totalAmount = 0 %}
    {% set paidCount = 0 %}
    {% set unpaidCount = 0 %}
    {% set overdueCount = 0 %}
    {% set totalPaidAmount = 0 %}
    {% set totalUnpaidAmount = 0 %}
    
    {% for bill in bills %}
        {% set amount = bill.amount|default(0) %}
        {% set totalAmount = totalAmount + amount %}
        
        {% if bill.status == 'PAID' %}
            {% set paidCount = paidCount + 1 %}
            {% set totalPaidAmount = totalPaidAmount + amount %}
        {% else %}
            {% set unpaidCount = unpaidCount + 1 %}
            {% set totalUnpaidAmount = totalUnpaidAmount + amount %}
            {% set dueDay = bill.dueDay %}
            {% set daysUntilDue = dueDay - currentDay %}
            {% if daysUntilDue < 0 %}
                {% set overdueCount = overdueCount + 1 %}
            {% endif %}
        {% endif %}
    {% endfor %}
    
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-muted small text-uppercase fw-semibold mb-1">Total Bills</div>
                            <div class="h3 fw-bold mb-0" style="color: #1a1f36;">{{ bills|length }}</div>
                        </div>
                        <div class="text-muted" style="opacity: 0.5;">📋</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-muted small text-uppercase fw-semibold mb-1">Paid</div>
                            <div class="h3 fw-bold mb-0" style="color: #10b981;">{{ paidCount }}</div>
                            <small class="text-muted">${{ totalPaidAmount|number_format(2) }}</small>
                        </div>
                        <div class="text-muted" style="opacity: 0.5;">✅</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-muted small text-uppercase fw-semibold mb-1">Unpaid</div>
                            <div class="h3 fw-bold mb-0" style="color: #ef4444;">{{ unpaidCount }}</div>
                            <small class="text-muted">${{ totalUnpaidAmount|number_format(2) }}</small>
                        </div>
                        <div class="text-muted" style="opacity: 0.5;">⚠️</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-muted small text-uppercase fw-semibold mb-1">Overdue</div>
                            <div class="h3 fw-bold mb-0" style="color: #dc2626;">{{ overdueCount }}</div>
                        </div>
                        <div class="text-muted" style="opacity: 0.5;">⏰</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

{# ── FullCalendar ─────────────────────────────────────── #}
<div class="mt-4" style="background:#fff; border-radius:12px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); overflow:hidden;">

    <div style="padding: 1rem 1.5rem; border-bottom: 1px solid #f0f2f5; display:flex; justify-content:space-between; align-items:center;">
        <span style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.8px; color:#8a94a6;">
            📅 Bill Calendar
        </span>
        <div style="display:flex; gap:0.5rem;">
            <span style="font-size:0.72rem; color:#8a94a6; display:flex; align-items:center; gap:4px;">
                <span style="width:10px;height:10px;background:#e7f1ff;border:1px solid #b6d4fe;border-radius:2px;display:inline-block;"></span> Unpaid
            </span>
            <span style="font-size:0.72rem; color:#8a94a6; display:flex; align-items:center; gap:4px;">
                <span style="width:10px;height:10px;background:#f8f9fa;border:1px solid #ced4da;border-radius:2px;display:inline-block;"></span> Paid
            </span>
        </div>
    </div>

    <div style="padding: 1.5rem;">
        <div id="billCalendar"></div>
    </div>
</div>

{# ── Bill Detail Modal ────────────────────────────────── #}
<div id="billModal" style="
    display:none;
    position:fixed;
    top:0;left:0;right:0;bottom:0;
    background:rgba(0,0,0,0.4);
    z-index:9999;
    align-items:center;
    justify-content:center;
">
    <div style="
        background:#fff;
        border-radius:16px;
        padding:2rem;
        width:340px;
        box-shadow:0 20px 60px rgba(0,0,0,0.2);
        position:relative;
    ">
        <button onclick="closeModal()" style="
            position:absolute;top:1rem;right:1rem;
            background:none;border:none;font-size:1.2rem;
            color:#8a94a6;cursor:pointer;
        ">✕</button>
        <h6 id="modalTitle" style="font-weight:700;color:#1a1f36;margin-bottom:1rem;font-size:1rem;"></h6>
        <div id="modalBody"></div>
    </div>
</div>



    {# ── Bills Table ─────────────────────────────────────────── #}
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-header bg-transparent border-0 pt-3 pb-0 px-0 mx-3">
            <div class="d-flex justify-content-between align-items-center">
                <h6 class="text-muted fw-semibold mb-0 small text-uppercase tracking-wide">All Bills</h6>
                <div class="text-muted small">
                    <span class="me-2">● Paid</span>
                    <span class="me-2">● Overdue</span>
                    <span>● Pending</span>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            {% if bills is empty %}
                <div class="text-center py-5 text-muted">
                    <div class="mb-3" style="font-size: 3rem;">📭</div>
                    <p class="mb-2">No bills recorded yet</p>
                    {% if budgets is defined and budgets|length > 0 %}
                        <a href="{{ path('finance_bill_new', {'id': budgets[0].id}) }}" class="btn btn-dark btn-sm">
                            Create your first bill
                        </a>
                    {% else %}
                        <a href="{{ path('finance_budget_new') }}" class="btn btn-dark btn-sm">
                            Create a budget first
                        </a>
                    {% endif %}
                </div>
            {% else %}
            <div class="table-responsive">
                <table class="table table-hover mb-0" style="min-width: 800px;">
                    <thead style="background-color: #f8f9fa; border-bottom: 1px solid #e9ecef;">
                        <tr>
                            <th class="ps-3 py-3 small fw-semibold text-muted text-uppercase">Bill</th>
                            <th class="py-3 small fw-semibold text-muted text-uppercase">Amount</th>
                            <th class="py-3 small fw-semibold text-muted text-uppercase">Due</th>
                            <th class="py-3 small fw-semibold text-muted text-uppercase">Frequency</th>
                            <th class="py-3 small fw-semibold text-muted text-uppercase">Budget</th>
                            <th class="py-3 small fw-semibold text-muted text-uppercase">Status</th>
                            <th class="pe-3 py-3 small fw-semibold text-muted text-uppercase text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for bill in bills %}
                            {% set dueDay = bill.dueDay %}
                            {% set daysUntilDue = dueDay - currentDay %}
                            
                            {% if bill.status == 'PAID' %}
                                {% set statusColor = '#10b981' %}
                                {% set statusText = 'Paid' %}
                            {% elseif daysUntilDue < 0 %}
                                {% set statusColor = '#dc2626' %}
                                {% set statusText = 'Overdue' %}
                            {% elseif daysUntilDue <= 3 %}
                                {% set statusColor = '#f59e0b' %}
                                {% set statusText = 'Due Soon' %}
                            {% else %}
                                {% set statusColor = '#6b7280' %}
                                {% set statusText = 'Pending' %}
                            {% endif %}
                            
                            <tr>
                                <td class="ps-3 py-3">
                                    <div class="fw-semibold" style="color: #1a1f36;">{{ bill.name }}</div>
                                    {% if bill.category %}
                                        <small class="text-muted">{{ bill.category }}</small>
                                    {% endif %}
                                </td>
                                <td class="py-3 fw-semibold" style="color: #1a1f36;">${{ bill.amount|number_format(2) }}</td>
                                <td class="py-3">
                                    <span class="small">Day {{ bill.dueDay }}</span>
                                    {% if daysUntilDue >= 0 and daysUntilDue <= 7 and bill.status != 'PAID' %}
                                        <div class="small text-muted">in {{ daysUntilDue }} days</div>
                                    {% elseif daysUntilDue < 0 and bill.status != 'PAID' %}
                                        <div class="small" style="color: #dc2626;">{{ daysUntilDue|abs }} days overdue</div>
                                    {% endif %}
                                </td>
                                <td class="py-3">
                                    <span class="small text-muted">
                                        {% if bill.frequency == 'MONTHLY' %}Monthly
                                        {% elseif bill.frequency == 'WEEKLY' %}Weekly
                                        {% elseif bill.frequency == 'YEARLY' %}Yearly
                                        {% else %}{{ bill.frequency }}{% endif %}
                                    </span>
                                </td>
                                <td class="py-3">
                                    <a href="{{ path('finance_budget_show', {'id': bill.budget.id}) }}" class="text-decoration-none small">
                                        {{ bill.budget.name }}
                                    </a>
                                </td>
                                <td class="py-3">
                                    <span class="badge rounded-pill px-3 py-1 fw-normal" style="background-color: {{ statusColor }}10; color: {{ statusColor }}; border: 1px solid {{ statusColor }}20;">
                                        {{ statusText }}
                                    </span>
                                </td>
                                <td class="pe-3 py-3 text-end">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a href="{{ path('finance_bill_edit', {'id': bill.id}) }}" 
                                           class="btn btn-link text-secondary text-decoration-none p-1" title="Edit">
                                            ✏️
                                        </a>
                                        {% if bill.status != 'PAID' %}
                                            <form action="{{ path('finance_bill_pay', {'id': bill.id}) }}" 
                                                  method="post" class="d-inline">
                                                <input type="hidden" name="_token" 
                                                       value="{{ csrf_token('pay_bill_' ~ bill.id) }}">
                                                <button class="btn btn-link text-success text-decoration-none p-1" title="Mark as Paid" 
                                                        onclick="return confirm('Mark this bill as paid?')">
                                                    ✅
                                                </button>
                                            </form>
                                        {% endif %}
                                        <form action="{{ path('finance_bill_delete', {'id': bill.id}) }}" 
                                              method="post" class="d-inline"
                                              onsubmit="return confirm('Delete this bill?')">
                                            <input type="hidden" name="_token" 
                                                   value="{{ csrf_token('delete_bill_' ~ bill.id) }}">
                                            <button class="btn btn-link text-danger text-decoration-none p-1" title="Delete">
                                                🗑
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}
        </div>
    </div>
    
    {# ── Footer Summary ───────────────────────────────────────── #}
    {% if bills|length > 0 %}
    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 bg-transparent">
                <div class="card-body p-3">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="small text-muted mb-1">Total Outstanding</div>
                            <div class="h5 fw-semibold mb-0" style="color: #1a1f36;">${{ totalUnpaidAmount|number_format(2) }}</div>
                        </div>
                        <div class="col-md-4">
                            <div class="small text-muted mb-1">Payment Rate</div>
                            <div class="h5 fw-semibold mb-0" style="color: #1a1f36;">{{ paidCount > 0 ? ((paidCount / bills|length) * 100)|round : 0 }}%</div>
                            <div class="progress mt-2" style="height: 4px;">
                                <div class="progress-bar" role="progressbar" style="width: {{ paidCount > 0 ? ((paidCount / bills|length) * 100)|round : 0 }}%; background-color: #10b981;"></div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="small text-muted mb-1">Monthly Commitment</div>
                            <div class="h5 fw-semibold mb-0" style="color: #1a1f36;">${{ (totalAmount / 12)|number_format(2) }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

</div>

<style>
    .tracking-wide {
        letter-spacing: 0.5px;
    }
    .btn-link {
        opacity: 0.6;
        transition: opacity 0.2s;
    }
    .btn-link:hover {
        opacity: 1;
    }
    .table > :not(caption) > * > * {
        border-bottom-color: #f0f0f0;
    }
    .table tbody tr:hover {
        background-color: #fafafa;
    }
    .badge {
        font-weight: 500;
    }
    .progress {
        background-color: #f0f0f0;
    }
</style>
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js'></script>
<script>
// ── Notification bell ──────────────────────────────────
function toggleNotif() {
    const dropdown = document.getElementById('notifDropdown');
    dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
}
document.addEventListener('click', function(e) {
    const wrapper = document.getElementById('notifWrapper');
    if (wrapper && !wrapper.contains(e.target)) {
        document.getElementById('notifDropdown').style.display = 'none';
    }
});

// ── FullCalendar ───────────────────────────────────────
document.addEventListener('DOMContentLoaded', function() {
    const calendarEl = document.getElementById('billCalendar');
    const events     = {{ events|raw }};

    const calendar = new FullCalendar.Calendar(calendarEl, {
        initialView:  'dayGridMonth',
        headerToolbar: {
            left:   'prev,next today',
            center: 'title',
            right:  'dayGridMonth,dayGridWeek'
        },
        height:       'auto',
        firstDay:     1,
        events:       events,
        eventClick: function(info) {
            const p = info.event.extendedProps;
            document.getElementById('modalTitle').textContent = info.event.title;
            document.getElementById('modalBody').innerHTML = `
                <div style="display:flex;flex-direction:column;gap:0.6rem;">
                    <div style="display:flex;justify-content:space-between;padding:0.5rem 0;border-bottom:1px solid #f0f2f5;">
                        <span style="font-size:0.82rem;color:#8a94a6;">Status</span>
                        <span style="font-size:0.82rem;font-weight:600;color:${p.status === 'PAID' ? '#16a34a' : '#e74c3c'};">
                            ${p.status}
                        </span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:0.5rem 0;border-bottom:1px solid #f0f2f5;">
                        <span style="font-size:0.82rem;color:#8a94a6;">Amount</span>
                        <span style="font-size:0.82rem;font-weight:600;color:#1a1f36;">${parseFloat(p.amount).toFixed(2)} TND</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:0.5rem 0;border-bottom:1px solid #f0f2f5;">
                        <span style="font-size:0.82rem;color:#8a94a6;">Frequency</span>
                        <span style="font-size:0.82rem;font-weight:600;color:#1a1f36;">${p.frequency}</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:0.5rem 0;">
                        <span style="font-size:0.82rem;color:#8a94a6;">Category</span>
                        <span style="font-size:0.82rem;font-weight:600;color:#1a1f36;">${p.category || 'N/A'}</span>
                    </div>
                </div>
            `;
            document.getElementById('billModal').style.display = 'flex';
        },
        eventMouseEnter: function(info) {
            info.el.style.cursor = 'pointer';
            info.el.style.opacity = '0.85';
        },
        eventMouseLeave: function(info) {
            info.el.style.opacity = '1';
        },
        dayMaxEvents: 3,
        moreLinkClick: 'popover',
    });

    calendar.render();
});

function closeModal() {
    document.getElementById('billModal').style.display = 'none';
}

// close modal clicking outside
document.getElementById('billModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
});
</script>

{% endblock %}