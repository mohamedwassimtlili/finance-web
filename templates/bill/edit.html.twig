{% extends 'base.html.twig' %}
{% block title %}Edit Bill{% endblock %}
{% block body %}
<div class="container py-4" style="max-width: 600px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">✏️ Edit Bill</h3>
        <a href="{{ path('finance_bills') }}" class="btn btn-outline-secondary btn-sm">← Back</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form method="post">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Bill Name <span class="text-danger">*</span></label>
                    <input type="text" name="name" class="form-control"
                           value="{{ bill.name }}" minlength="2" maxlength="100" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Amount (TND) <span class="text-danger">*</span></label>
                    <input type="number" name="amount" step="0.01" min="0.01" max="999999.99"
                           class="form-control" value="{{ bill.amount }}" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Due Day (1-31) <span class="text-danger">*</span></label>
                    <input type="number" name="due_day" min="1" max="31"
                           class="form-control" value="{{ bill.dueDay }}" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Frequency <span class="text-danger">*</span></label>
                    <select name="frequency" class="form-select" required>
                        <option value="MONTHLY" {{ bill.frequency == 'MONTHLY' ? 'selected' : '' }}>Monthly</option>
                        <option value="WEEKLY"  {{ bill.frequency == 'WEEKLY'  ? 'selected' : '' }}>Weekly</option>
                        <option value="YEARLY"  {{ bill.frequency == 'YEARLY'  ? 'selected' : '' }}>Yearly</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Category</label>
                    <input type="text" name="category" class="form-control"
                           maxlength="50" value="{{ bill.category }}">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea name="description" class="form-control" rows="2" maxlength="255">{{ bill.description }}</textarea>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                    <a href="{{ path('finance_bills') }}" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}