{% extends 'base.html.twig' %}

{% block title %}Bill{% endblock %}

{% block body %}
    <h1>Bill</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ bill.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ bill.name }}</td>
            </tr>
            <tr>
                <th>Amount</th>
                <td>{{ bill.amount }}</td>
            </tr>
            <tr>
                <th>DueDay</th>
                <td>{{ bill.dueDay }}</td>
            </tr>
            <tr>
                <th>Frequency</th>
                <td>{{ bill.frequency }}</td>
            </tr>
            <tr>
                <th>Category</th>
                <td>{{ bill.category }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ bill.description }}</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>{{ bill.status }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ bill.createdAt ? bill.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_bill_index') }}">back to list</a>

    <a href="{{ path('app_bill_edit', {'id': bill.id}) }}">edit</a>

    {{ include('bill/_delete_form.html.twig') }}
{% endblock %}
