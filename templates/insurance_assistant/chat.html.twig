{% extends 'base.html.twig' %}

{% block title %}Insurance Assistant{% endblock %}
{% block page_title %}Insurance Assistant{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">

        {% for msg in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show">
                {{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
        {% for msg in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show">
                {{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <div class="card shadow-sm">

            {# ── Header ── #}
            <div class="card-header d-flex justify-content-between align-items-center"
                 style="background:linear-gradient(135deg,#0d6efd,#0dcaf0);">
                <h5 class="mb-0 text-white">
                    <i class="bi bi-robot me-2"></i>Insurance Assistant
                    <small class="fw-light ms-2 opacity-75">Powered by Groq · llama3-70b</small>
                </h5>
                <form method="post" action="{{ path('insurance_assistant_reset') }}" class="mb-0">
                    <button type="submit" class="btn btn-sm btn-outline-light"
                            onclick="return confirm('Reset the conversation?')">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                    </button>
                </form>
            </div>

            {# ── Chat window ── #}
            <div class="card-body p-0">
                <div id="chat-window"
                     style="height:420px;overflow-y:auto;padding:1rem;background:#f8f9fa;">

                    {% if history is empty %}
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-chat-dots" style="font-size:3rem;opacity:.4;"></i>
                            <p class="mt-2">Ask me anything about your insurance — packages, assets, premiums, or contracts.</p>
                        </div>
                    {% else %}
                        {% for msg in history %}
                            {% if msg.role == 'user' %}
                                <div class="d-flex justify-content-end mb-3">
                                    <div class="p-3 rounded-3 text-white"
                                         style="max-width:75%;background:#0d6efd;word-break:break-word;">
                                        {{ msg.content|nl2br }}
                                    </div>
                                    <span class="ms-2 align-self-end">
                                        <i class="bi bi-person-circle fs-4 text-primary"></i>
                                    </span>
                                </div>
                            {% else %}
                                <div class="d-flex justify-content-start mb-3">
                                    <span class="me-2 align-self-end">
                                        <i class="bi bi-robot fs-4 text-info"></i>
                                    </span>
                                    <div class="p-3 rounded-3 bg-white border"
                                         style="max-width:75%;word-break:break-word;">
                                        {{ msg.content|nl2br }}
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                    {% endif %}
                </div>
            </div>

            {# ── Input ── #}
            <div class="card-footer bg-white border-top">
                <form method="post" action="{{ path('insurance_assistant_chat') }}"
                      id="chat-form" class="d-flex gap-2">

                    <input type="text" name="message" id="message-input"
                           class="form-control"
                           placeholder="Ask about insurance packages, assets, premiums…"
                           autocomplete="off" required autofocus>

                    <button type="button" id="voice-btn"
                            class="btn btn-outline-secondary px-3"
                            title="Click to speak">
                        <i class="bi bi-mic-fill" id="voice-icon"></i>
                    </button>

                    <button type="submit" class="btn btn-primary px-4" id="send-btn">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </form>

                {# ── Bottom bar ── #}
                <div class="d-flex justify-content-between align-items-center mt-2">
                    <small class="text-muted">
                        <i class="bi bi-info-circle me-1"></i>
                        History remembered for this session. Use <strong>Reset</strong> to start fresh.
                        <span id="voice-status" class="ms-2 text-danger fw-semibold d-none"></span>
                    </small>

                    {# ── Speak replies toggle ── #}
                    <div class="form-check form-switch mb-0 ms-3 d-flex align-items-center gap-2">
                        <input class="form-check-input" type="checkbox"
                               role="switch" id="voice-reply-toggle" style="cursor:pointer;">
                        <label class="form-check-label text-muted small d-flex align-items-center gap-1"
                               for="voice-reply-toggle">
                            <i class="bi bi-volume-up-fill" id="speaker-icon" style="font-size:14px;"></i>
                            Speak replies
                        </label>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    {# ── Auto-scroll ── #}
    const win = document.getElementById('chat-window');
    if (win) win.scrollTop = win.scrollHeight;

    {# ── Disable send while submitting ── #}
    document.getElementById('chat-form')?.addEventListener('submit', function () {
        const btn = document.getElementById('send-btn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
    });

    {# ── Shared refs ── #}
    const voiceBtn    = document.getElementById('voice-btn');
    const voiceIcon   = document.getElementById('voice-icon');
    const voiceStatus = document.getElementById('voice-status');
    const msgInput    = document.getElementById('message-input');
    const toggle      = document.getElementById('voice-reply-toggle');
    const speakerIcon = document.getElementById('speaker-icon');

    {# ══════════════════════════════════════════
       1. TEXT-TO-SPEECH
    ══════════════════════════════════════════ #}
    const TTS_KEY = 'insurance_voice_reply';
    toggle.checked = localStorage.getItem(TTS_KEY) === 'true';
    updateSpeakerIcon();

    toggle.addEventListener('change', () => {
        localStorage.setItem(TTS_KEY, toggle.checked);
        updateSpeakerIcon();
        if (!toggle.checked) window.speechSynthesis.cancel();
    });

    function updateSpeakerIcon() {
        speakerIcon.className = toggle.checked
            ? 'bi bi-volume-up-fill text-primary'
            : 'bi bi-volume-mute text-muted';
    }

    function speakText(text) {
        if (!window.speechSynthesis || !toggle.checked) return;

        const clean = text
            .replace(/\*\*(.*?)\*\*/g, '$1')
            .replace(/\*(.*?)\*/g, '$1')
            .replace(/`(.*?)`/g, '$1')
            .replace(/#{1,6}\s/g, '')
            .trim();

        window.speechSynthesis.cancel();
        const utter  = new SpeechSynthesisUtterance(clean);
        utter.lang   = 'en-US';
        utter.rate   = 1;
        utter.pitch  = 1;
        utter.volume = 1;
        window.speechSynthesis.speak(utter);
    }

    {# Speak last assistant reply on page load if toggle is on #}
    const bubbles    = document.querySelectorAll('#chat-window .bi-robot');
    const lastBubble = bubbles.length
        ? bubbles[bubbles.length - 1].closest('.d-flex')?.querySelector('.p-3')
        : null;

    if (lastBubble && toggle.checked) {
        setTimeout(() => speakText(lastBubble.innerText), 400);
    }

    {# ══════════════════════════════════════════
       2. VOICE-TO-TEXT
    ══════════════════════════════════════════ #}
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

    if (!SpeechRecognition) {
        voiceBtn.style.display = 'none';
    } else {
        const recognition          = new SpeechRecognition();
        recognition.lang           = 'en-US';
        recognition.continuous     = false;
        recognition.interimResults = true;
        let isListening            = false;

        function startListening() {
            isListening = true;
            voiceBtn.classList.replace('btn-outline-secondary', 'btn-danger');
            voiceIcon.classList.replace('bi-mic-fill', 'bi-stop-fill');
            voiceStatus.textContent = 'Listening…';
            voiceStatus.classList.remove('d-none');
            msgInput.placeholder = 'Speak now…';
            recognition.start();
        }

        function stopListening() {
            isListening = false;
            voiceBtn.classList.replace('btn-danger', 'btn-outline-secondary');
            voiceIcon.classList.replace('bi-stop-fill', 'bi-mic-fill');
            voiceStatus.classList.add('d-none');
            msgInput.placeholder = 'Ask about insurance packages, assets, premiums…';
            recognition.stop();
        }

        voiceBtn.addEventListener('click', () =>
            isListening ? stopListening() : startListening()
        );

        recognition.addEventListener('result', (e) => {
            const transcript = Array.from(e.results)
                .map(r => r[0].transcript).join('');
            msgInput.value = transcript;

            if (e.results[e.results.length - 1].isFinal) {
                stopListening();
                if (transcript.trim())
                    document.getElementById('chat-form').requestSubmit();
            }
        });

        recognition.addEventListener('error', (e) => {
            stopListening();
            voiceStatus.textContent = 'Microphone error: ' + e.error;
            voiceStatus.classList.remove('d-none');
            setTimeout(() => voiceStatus.classList.add('d-none'), 3000);
        });

        recognition.addEventListener('end', () => {
            if (isListening) stopListening();
        });
    }
</script>
{% endblock %}