{% extends 'base.html.twig' %}

{% block title %}Insurance Assistant{% endblock %}
{% block page_title %}Insurance Assistant{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">

        {% for msg in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show">{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        {% endfor %}
        {% for msg in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show">{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        {% endfor %}

        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center"
                 style="background:linear-gradient(135deg,#0d6efd,#0dcaf0);">
                <h5 class="mb-0 text-white">
                    <i class="bi bi-robot me-2"></i>Insurance Assistant
                    <small class="fw-light ms-2 opacity-75">Powered by Groq · llama3-70b</small>
                </h5>
                <form method="post" action="{{ path('insurance_assistant_reset') }}" class="mb-0">
                    <button type="submit" class="btn btn-sm btn-outline-light"
                            onclick="return confirm('Reset the conversation?')">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                    </button>
                </form>
            </div>

            {# ── Chat window ── #}
            <div class="card-body p-0">
                <div id="chat-window"
                     style="height:420px;overflow-y:auto;padding:1rem;background:#f8f9fa;">

                    {% if history is empty %}
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-chat-dots" style="font-size:3rem;opacity:.4;"></i>
                            <p class="mt-2">Ask me anything about your insurance — packages, assets, premiums, or contracts.</p>
                        </div>
                    {% else %}
                        {% for msg in history %}
                            {% if msg.role == 'user' %}
                                <div class="d-flex justify-content-end mb-3">
                                    <div class="p-3 rounded-3 text-white"
                                         style="max-width:75%;background:#0d6efd;word-break:break-word;">
                                        {{ msg.content|nl2br }}
                                    </div>
                                    <span class="ms-2 align-self-end">
                                        <i class="bi bi-person-circle fs-4 text-primary"></i>
                                    </span>
                                </div>
                            {% else %}
                                <div class="d-flex justify-content-start mb-3">
                                    <span class="me-2 align-self-end">
                                        <i class="bi bi-robot fs-4 text-info"></i>
                                    </span>
                                    <div class="p-3 rounded-3 bg-white border"
                                         style="max-width:75%;word-break:break-word;">
                                        {{ msg.content|nl2br }}
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                    {% endif %}
                </div>
            </div>

            {# ── Input ── #}
            <div class="card-footer bg-white border-top">
                <form method="post" action="{{ path('insurance_assistant_chat') }}"
                      id="chat-form" class="d-flex gap-2">
                    <input type="text" name="message" id="message-input"
                           class="form-control"
                           placeholder="Ask about insurance packages, assets, premiums…"
                           autocomplete="off" required autofocus>
                    <button type="submit" class="btn btn-primary px-4" id="send-btn">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </form>
                <small class="text-muted mt-1 d-block">
                    <i class="bi bi-info-circle me-1"></i>
                    Your conversation history is remembered for this session.
                    Use <strong>Reset</strong> to start fresh.
                </small>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    // Auto-scroll chat window to bottom
    const win = document.getElementById('chat-window');
    if (win) win.scrollTop = win.scrollHeight;

    // Disable send button while submitting
    document.getElementById('chat-form')?.addEventListener('submit', function () {
        const btn = document.getElementById('send-btn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
    });
</script>
{% endblock %}
