{% extends 'base.html.twig' %}
{% block title %}Admin — Insurance Packages{% endblock %}
{% block page_title %}Insurance Packages{% endblock %}

{% block body %}
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label }} alert-dismissible fade show">
            {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endfor %}

<div class="row mb-3">
    <div class="col-12 d-flex justify-content-end">
        <a href="{{ path('admin_insurance_package_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> New Package
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header"><h3 class="card-title"><i class="bi bi-collection me-2"></i>All Packages</h3></div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Asset Type</th>
                    <th>Base Price</th>
                    <th>Multiplier</th>
                    <th>Duration</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for pkg in packages %}
                <tr>
                    <td>{{ pkg.id }}</td>
                    <td>
                        <strong>{{ pkg.name }}</strong>
                        {% if pkg.description %}<br><small class="text-muted">{{ pkg.description|slice(0,60) }}…</small>{% endif %}
                    </td>
                    <td><span class="badge text-bg-info">{{ pkg.assetType }}</span></td>
                    <td>{{ pkg.basePrice }} TND</td>
                    <td>×{{ pkg.riskMultiplier }}</td>
                    <td>{{ pkg.durationMonths }} months</td>
                    <td>
                        {% if pkg.isActive %}
                            <span class="badge text-bg-success">Active</span>
                        {% else %}
                            <span class="badge text-bg-secondary">Inactive</span>
                        {% endif %}
                    </td>
                    <td class="text-nowrap">
                        <a href="{{ path('admin_insurance_package_edit', {id: pkg.id}) }}" class="btn btn-sm btn-outline-warning">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form method="post" action="{{ path('admin_insurance_package_toggle', {id: pkg.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle-pkg-' ~ pkg.id) }}">
                            <button class="btn btn-sm btn-outline-{{ pkg.isActive ? 'secondary' : 'success' }}" title="{{ pkg.isActive ? 'Deactivate' : 'Activate' }}">
                                <i class="bi bi-{{ pkg.isActive ? 'toggle-off' : 'toggle-on' }}"></i>
                            </button>
                        </form>
                        <form method="post" action="{{ path('admin_insurance_package_delete', {id: pkg.id}) }}" class="d-inline"
                              onsubmit="return confirm('Delete package permanently?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('del-pkg-' ~ pkg.id) }}">
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="8" class="text-center text-muted py-4">No packages found.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
