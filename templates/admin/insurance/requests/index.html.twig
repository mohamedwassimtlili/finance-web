{% extends 'base.html.twig' %}
{% block title %}Admin — Contract Requests{% endblock %}
{% block page_title %}All Contract Requests{% endblock %}

{% block body %}
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label }} alert-dismissible fade show">
            {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endfor %}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="bi bi-file-earmark-text me-2"></i>Contract Requests</h3>
        <div class="card-tools">
            <span class="badge text-bg-secondary">{{ requests|length }} total</span>
        </div>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>User</th>
                    <th>Asset</th>
                    <th>Package</th>
                    <th>Premium</th>
                    <th>Status</th>
                    <th>Submitted</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for req in requests %}
                {% set statusClass = {
                    'PENDING':   'warning',
                    'APPROVED':  'success',
                    'REJECTED':  'danger',
                    'CANCELLED': 'secondary'
                }[req.status] ?? 'secondary' %}
                <tr>
                    <td>{{ req.id }}</td>
                    <td>
                        <span class="fw-bold">{{ req.user.name }}</span>
                        <br><small class="text-muted">{{ req.user.email }}</small>
                    </td>
                    <td>{{ req.asset.reference }} <small class="text-muted">({{ req.asset.type }})</small></td>
                    <td>{{ req.package.name }}</td>
                    <td>{{ req.calculatedPremium }} TND</td>
                    <td><span class="badge text-bg-{{ statusClass }}">{{ req.status }}</span></td>
                    <td>{{ req.createdAt ? req.createdAt|date('Y-m-d') : '—' }}</td>
                    <td>
                        {% if req.status == 'PENDING' %}
                        <form method="post" action="{{ path('admin_insurance_request_approve', {id: req.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('approve-' ~ req.id) }}">
                            <button class="btn btn-sm btn-success" title="Approve">
                                <i class="bi bi-check-circle"></i> Approve
                            </button>
                        </form>
                        <form method="post" action="{{ path('admin_insurance_request_reject', {id: req.id}) }}" class="d-inline"
                              onsubmit="return confirm('Reject this request?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('reject-' ~ req.id) }}">
                            <button class="btn btn-sm btn-danger" title="Reject">
                                <i class="bi bi-x-circle"></i> Reject
                            </button>
                        </form>
                        {% else %}
                            <span class="text-muted small">—</span>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="8" class="text-center text-muted py-4">No requests found.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
