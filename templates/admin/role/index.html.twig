{% extends 'base.html.twig' %}

{% block title %}Manage Roles{% endblock %}
{% block page_title %}Manage Roles{% endblock %}

{% block body %}
{% for msg in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">Define system roles and their permissions.</p>
    <a href="{{ path('admin_role_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>New Role
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <h3 class="card-title"><i class="bi bi-person-badge me-2"></i>Role List</h3>
        <span class="badge bg-secondary ms-2">{{ roles|length }} total</span>
    </div>
    <div class="card-body p-0">
        {% if roles is empty %}
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox" style="font-size:3rem;"></i>
                <p class="mt-2">No roles defined yet.</p>
            </div>
        {% else %}
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Role Name</th>
                        <th>Permissions</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for role in roles %}
                    <tr>
                        <td>{{ role.id }}</td>
                        <td><strong>{{ role.roleName }}</strong></td>
                        <td><small class="text-muted">{{ role.permissions|default('—')|nl2br }}</small></td>
                        <td class="text-end">
                            <a href="{{ path('admin_role_edit', {id: role.id}) }}" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <form method="post" action="{{ path('admin_role_delete', {id: role.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Delete role {{ role.roleName }}?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_role_' ~ role.id) }}">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Delete</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}
