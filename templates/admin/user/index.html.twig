{% extends 'base.html.twig' %}

{% block title %}Admin – Manage Users{% endblock %}
{% block page_title %}Manage Users{% endblock %}

{% block body %}

{# ── Flash messages ─────────────────────────────────────────────────────────── #}
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
            <i class="bi bi-{{ label == 'success' ? 'check-circle' : (label == 'danger' ? 'x-circle' : 'info-circle') }} me-2"></i>
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endfor %}

<div class="row g-4">

    {# ═══════════════════════════════════════════════════════════════════════════
       LEFT COLUMN — Add New User Form (like JavaFX side panel)
    ═══════════════════════════════════════════════════════════════════════════ #}
    <div class="col-xl-3 col-lg-4">
        <div class="card card-primary card-outline h-100">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-person-plus-fill me-2"></i>Add New User
                </h3>
            </div>
            <div class="card-body">
                <form method="post" action="{{ path('admin_user_new') }}" novalidate>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input type="text" name="name" class="form-control"
                                   placeholder="e.g. Ahmed Ben Ali" required
                                   pattern="[a-zA-Z\s]+" title="Letters and spaces only">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input type="email" name="email" class="form-control"
                                   placeholder="user@example.com" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Phone</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                            <input type="text" name="phone" class="form-control"
                                   placeholder="8 digits" maxlength="8"
                                   pattern="[0-9]{8}" title="Exactly 8 digits"
                                   oninput="this.value=this.value.replace(/[^0-9]/g,'')">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Password <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input type="password" name="password" id="newUserPwd"
                                   class="form-control" placeholder="Min 6 chars" required minlength="6">
                            <button class="btn btn-outline-secondary" type="button"
                                    onclick="togglePwd('newUserPwd', this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Role <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-shield"></i></span>
                            <select name="roleId" class="form-select">
                                <option value="2" selected>User</option>
                                <option value="1">Admin</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-2"></i>Create User
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════════════════
       RIGHT COLUMN — Users Table
    ═══════════════════════════════════════════════════════════════════════════ #}
    <div class="col-xl-9 col-lg-8">

        {# Stats row #}
        <div class="row g-3 mb-4">
            <div class="col-sm-3">
                <div class="info-box bg-primary text-white mb-0">
                    <span class="info-box-icon"><i class="bi bi-people-fill"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">Total Users</span>
                        <span class="info-box-number">{{ users|length }}</span>
                    </div>
                </div>
            </div>
            <div class="col-sm-3">
                <div class="info-box bg-success text-white mb-0">
                    <span class="info-box-icon"><i class="bi bi-person-check-fill"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">Active</span>
                        <span class="info-box-number">{{ users|filter(u => u.isActive)|length }}</span>
                    </div>
                </div>
            </div>
            <div class="col-sm-3">
                <div class="info-box bg-warning text-white mb-0">
                    <span class="info-box-icon"><i class="bi bi-patch-check-fill"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">Verified</span>
                        <span class="info-box-number">{{ users|filter(u => u.isVerified)|length }}</span>
                    </div>
                </div>
            </div>
            <div class="col-sm-3">
                <div class="info-box bg-danger text-white mb-0">
                    <span class="info-box-icon"><i class="bi bi-shield-fill"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">Admins</span>
                        <span class="info-box-number">{{ users|filter(u => u.roleId == 1)|length }}</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h3 class="card-title mb-0">All Users</h3>
                <form method="get" class="d-flex gap-2">
                    <input type="text" name="q" value="{{ search_term }}"
                           class="form-control form-control-sm"
                           placeholder="Search name or email…" style="width:220px">
                    <button class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-search"></i>
                    </button>
                    {% if search_term %}
                        <a href="{{ path('admin_user_index') }}" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-x"></i>
                        </a>
                    {% endif %}
                </form>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover align-middle text-nowrap mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>User</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Last Login</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for user in users %}
                        <tr>
                            <td class="text-muted small">{{ user.id }}</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    {# DiceBear-style generated avatar (CSS, no external call) #}
                                    <div class="user-avatar-circle"
                                         style="background:{{ loop.index is odd ? '#3b82f6' : '#8b5cf6' }}">
                                        {{ user.name|first|upper }}
                                    </div>
                                    <div>
                                        <div class="fw-semibold">{{ user.name }}</div>
                                        {% if user.isVerified %}
                                            <span class="badge text-bg-success" style="font-size:.65rem">
                                                <i class="bi bi-check2"></i> verified
                                            </span>
                                        {% else %}
                                            <span class="badge text-bg-warning" style="font-size:.65rem">
                                                <i class="bi bi-clock"></i> pending
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>
                            </td>
                            <td>{{ user.email }}</td>
                            <td>{{ user.phone ?? '—' }}</td>
                            <td>
                                {% if user.roleId == 1 %}
                                    <span class="badge text-bg-danger"><i class="bi bi-shield-fill me-1"></i>Admin</span>
                                {% else %}
                                    <span class="badge text-bg-secondary"><i class="bi bi-person me-1"></i>User</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if user.isActive %}
                                    <span class="badge text-bg-success">
                                        <i class="bi bi-circle-fill me-1" style="font-size:.4rem;vertical-align:middle"></i>Active
                                    </span>
                                {% else %}
                                    <span class="badge text-bg-secondary">
                                        <i class="bi bi-circle me-1" style="font-size:.4rem;vertical-align:middle"></i>Disabled
                                    </span>
                                {% endif %}
                            </td>
                            <td class="small text-muted">
                                {{ user.lastLogin ? user.lastLogin|date('d/m/Y H:i') : '—' }}
                            </td>
                            <td>
                                <div class="d-flex gap-1 justify-content-center">

                                    {# Edit #}
                                    <a href="{{ path('admin_user_edit', {id: user.id}) }}"
                                       class="btn btn-sm btn-warning" title="Edit user">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    {# Toggle active #}
                                    <form method="post" action="{{ path('admin_user_toggle_active', {id: user.id}) }}">
                                        <input type="hidden" name="_token"
                                               value="{{ csrf_token('toggle-' ~ user.id) }}">
                                        <button class="btn btn-sm {{ user.isActive ? 'btn-outline-secondary' : 'btn-success' }}"
                                                title="{{ user.isActive ? 'Deactivate' : 'Activate' }}">
                                            <i class="bi {{ user.isActive ? 'bi-person-dash' : 'bi-person-check' }}"></i>
                                        </button>
                                    </form>

                                    {# Reset password modal trigger #}
                                    <button class="btn btn-sm btn-info" title="Reset password"
                                            data-bs-toggle="modal"
                                            data-bs-target="#resetPwdModal"
                                            data-user-id="{{ user.id }}"
                                            data-user-name="{{ user.name }}"
                                            data-reset-url="{{ path('admin_user_reset_password', {id: user.id}) }}">
                                        <i class="bi bi-key"></i>
                                    </button>

                                    {# Delete #}
                                    {% if user != app.user %}
                                    <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}"
                                          onsubmit="return confirm('Delete {{ user.name }}? This is permanent.')">
                                        <input type="hidden" name="_token"
                                               value="{{ csrf_token('delete-user-' ~ user.id) }}">
                                        <button class="btn btn-sm btn-danger" title="Delete user">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                    {% endif %}

                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <i class="bi bi-people display-6 d-block mb-2"></i>
                                No users found{% if search_term %} for "{{ search_term }}"{% endif %}.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

{# ── Reset Password Modal ───────────────────────────────────────────────────── #}
<div class="modal fade" id="resetPwdModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title"><i class="bi bi-key me-2"></i>Reset Password</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" id="resetPwdForm">
                <input type="hidden" name="_token" id="resetPwdToken">
                <div class="modal-body">
                    <p>Set a new password for <strong id="resetPwdName"></strong>:</p>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input type="password" name="new_password" id="resetPwdInput"
                               class="form-control" placeholder="New password (min 6 chars)"
                               required minlength="6">
                        <button class="btn btn-outline-secondary" type="button"
                                onclick="togglePwd('resetPwdInput', this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-info text-white">
                        <i class="bi bi-check-circle me-1"></i>Reset Password
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
// Populate reset-password modal with the right user
document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('resetPwdModal');
    modal.addEventListener('show.bs.modal', e => {
        const btn = e.relatedTarget;
        document.getElementById('resetPwdName').textContent  = btn.dataset.userName;
        document.getElementById('resetPwdForm').action       = btn.dataset.resetUrl;
        document.getElementById('resetPwdToken').value       =
            '{{ csrf_token("reset-pwd-0") }}'.replace('-0', '-' + btn.dataset.userId);
    });
});

// Toggle password visibility
function togglePwd(inputId, btn) {
    const input = document.getElementById(inputId);
    const isText = input.type === 'text';
    input.type = isText ? 'password' : 'text';
    btn.querySelector('i').className = isText ? 'bi bi-eye' : 'bi bi-eye-slash';
}
</script>

<style>
.user-avatar-circle {
    width: 36px; height: 36px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-weight: 700; font-size: .9rem;
    flex-shrink: 0;
}
.info-box {
    border-radius: 8px;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 2px 6px rgba(0,0,0,.08);
}
.info-box-icon { font-size: 1.8rem; opacity: .85; }
.info-box-content { flex: 1; }
.info-box-text { display: block; font-size: .78rem; opacity: .9; }
.info-box-number { display: block; font-size: 1.5rem; font-weight: 700; line-height: 1.2; }
</style>
{% endblock %}
