{% extends 'base.html.twig' %}

{% block title %}All Expenses (Admin){% endblock %}
{% block page_title %}All Expenses{% endblock %}

{% block body %}
<div class="card shadow-sm">
    <div class="card-header">
        <h3 class="card-title"><i class="bi bi-receipt me-2"></i>Expense Directory</h3>
        <span class="badge bg-secondary ms-2">{{ expenses|length }} total</span>
    </div>
    <div class="card-body p-0">
        {% if expenses is empty %}
            <div class="text-center py-5 text-muted"><i class="bi bi-inbox" style="font-size:3rem;"></i><p class="mt-2">No expenses found.</p></div>
        {% else %}
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>#</th><th>Owner</th><th>Budget</th><th>Amount (TND)</th><th>Category</th><th>Date</th><th>Description</th></tr>
                </thead>
                <tbody>
                {% for e in expenses %}
                    <tr>
                        <td>{{ e.id }}</td>
                        <td>{{ e.budget.user.name }}<br><small class="text-muted">{{ e.budget.user.email }}</small></td>
                        <td>{{ e.budget.name }}</td>
                        <td>{{ e.amount|number_format(2,'.', ',') }}</td>
                        <td>{{ e.category|default('—') }}</td>
                        <td>{{ e.expenseDate|date('d/m/Y') }}</td>
                        <td>{{ e.description|default('—')|slice(0,60) }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}
