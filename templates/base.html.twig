<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}My App{% endblock %}</title>

    {# AdminLTE CSS #}
    <link rel="stylesheet" href="{{ asset('adminlte/css/adminlte.min.css') }}">

    {# Bootstrap Icons (via CDN since no npm) #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="icon" type="image/x-icon" href="{{ asset('favicon.ico') }}">
    <style>
        /* Profile link in navbar */
        .nav-profile-link {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 4px 10px;
            border-radius: 50px;
            text-decoration: none;
            color: inherit;
            transition: background 0.18s ease;
        }
        .nav-profile-link:hover {
            background: rgba(0, 0, 0, 0.07);
            color: inherit;
        }
        .nav-profile-link .nav-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid rgba(99, 102, 241, 0.35);
            transition: border-color 0.18s;
        }
        .nav-profile-link:hover .nav-avatar {
            border-color: rgba(99, 102, 241, 0.75);
        }
        .nav-avatar-fallback {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
            border: 2px solid rgba(99, 102, 241, 0.35);
        }
    </style>
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">

<div class="app-wrapper">

    {# ===== TOP NAVBAR ===== #}
    <nav class="app-header navbar navbar-expand bg-body">
        <div class="container-fluid">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                        <i class="bi bi-list"></i>
                    </a>
                </li>
            </ul>
            <ul class="navbar-nav ms-auto">
                {% if app.user %}
                <li class="nav-item">
                    {# Clicking the avatar/name goes directly to the profile page #}
                    <a href="{{ path('app_profile') }}" class="nav-link nav-profile-link" title="My Profile">
                        {# Fallback initials shown immediately #}
                        <span class="nav-avatar-fallback" id="navAvatarFallback">
                            {{ app.user.name|default('U')|split(' ')|map(p => p|first|upper)|join('')|slice(0,2) }}
                        </span>
                        {# DiceBear avatar loaded via JS — hidden until ready #}
                        <img id="navAvatarImg"
                             src=""
                             alt="avatar"
                             class="nav-avatar"
                             style="display:none"
                             data-seed="{{ app.user.name|default('User')|url_encode }}">
                        <span class="d-none d-md-inline fw-medium">{{ app.user.name|default('User') }}</span>
                        <i class="bi bi-chevron-right d-none d-md-inline text-muted" style="font-size:.7rem"></i>
                    </a>
                </li>
                {% endif %}
            </ul>
        </div>
    </nav>

    {# ===== SIDEBAR ===== #}
    <aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
        <div class="d-flex flex-column h-100">

            <div class="sidebar-brand">
                <a href="{{ path('app_home') }}" class="brand-link">
                    <span class="brand-text fw-light">MyApp</span>
                </a>
            </div>

            <div class="sidebar-wrapper flex-grow-1">
                <nav class="mt-2">
                    <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview">

                        <li class="nav-item">
                            <a href="{{ path('app_home') }}" class="nav-link">
                                <i class="nav-icon bi bi-speedometer2"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>

                        {# ── Insurance ── #}
                        <li class="nav-item has-treeview">
                            <a href="#" class="nav-link">
                                <i class="nav-icon bi bi-shield-fill"></i>
                                <p>Insurance <i class="nav-arrow bi bi-chevron-right ms-auto"></i></p>
                            </a>
                            <ul class="nav nav-treeview ps-3">
                                <li class="nav-item">
                                    <a href="{{ path('insurance_assets') }}" class="nav-link">
                                        <i class="nav-icon bi bi-hdd-rack"></i>
                                        <p>My Assets</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('insurance_packages') }}" class="nav-link">
                                        <i class="nav-icon bi bi-collection"></i>
                                        <p>Packages</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('insurance_requests') }}" class="nav-link">
                                        <i class="nav-icon bi bi-file-earmark-text"></i>
                                        <p>My Requests</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('insurance_assistant_chat') }}" class="nav-link">
                                        <i class="nav-icon bi bi-robot"></i>
                                        <p>AI Assistant</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        {# ── Loans ── #}
                        <li class="nav-item has-treeview">
                            <a href="#" class="nav-link">
                                <i class="nav-icon bi bi-bank"></i>
                                <p>Loans <i class="nav-arrow bi bi-chevron-right ms-auto"></i></p>
                            </a>
                            <ul class="nav nav-treeview ps-3">
                                <li class="nav-item">
                                    <a href="{{ path('loan_index') }}" class="nav-link">
                                        <i class="nav-icon bi bi-list-ul"></i>
                                        <p>My Loans</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('loan_new') }}" class="nav-link">
                                        <i class="nav-icon bi bi-plus-circle"></i>
                                        <p>Request a Loan</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('loan_repayments') }}" class="nav-link">
                                        <i class="nav-icon bi bi-calendar-check"></i>
                                        <p>My Repayments</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        {# ── Personal Finance ── #}
                        <li class="nav-item has-treeview">
                            <a href="#" class="nav-link">
                                <i class="nav-icon bi bi-wallet2"></i>
                                <p>Personal Finance <i class="nav-arrow bi bi-chevron-right ms-auto"></i></p>
                            </a>
                            <ul class="nav nav-treeview ps-3">
                                <li class="nav-item">
                                    <a href="{{ path('finance_budgets') }}" class="nav-link">
                                        <i class="nav-icon bi bi-grid-1x2"></i>
                                        <p>My Budgets</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('finance_expenses') }}" class="nav-link">
                                        <i class="nav-icon bi bi-receipt"></i>
                                        <p>My Expenses</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('finance_bills') }}" class="nav-link">
                                        <i class="nav-icon bi bi-file-earmark-text"></i>
                                        <p>My Bills</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        {# ── Payments & Complaints ── #}
                        <li class="nav-item has-treeview">
                            <a href="#" class="nav-link">
                                <i class="nav-icon bi bi-grid-1x2"></i>
                                <p>Pay &amp; Complaints <i class="nav-arrow bi bi-chevron-right ms-auto"></i></p>
                            </a>
                            <ul class="nav nav-treeview ps-3">
                                <li class="nav-item">
                                    <a href="{{ path('payment_index') }}" class="nav-link">
                                        <i class="nav-icon bi bi-list-ul"></i>
                                        <p>My Payments</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('payment_create') }}" class="nav-link">
                                        <i class="nav-icon bi bi-plus-circle"></i>
                                        <p>Make a Payment</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('complaint_index') }}" class="nav-link">
                                        <i class="nav-icon bi bi-megaphone"></i>
                                        <p>My Complaints</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('complaint_new') }}" class="nav-link">
                                        <i class="nav-icon bi bi-chat-left-text"></i>
                                        <p>New Complaint</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        {# ══ ADMIN SECTION ══════════════════════════════════════════════════════ #}
                        {% if is_granted('ROLE_ADMIN') %}

                        <li class="nav-header text-uppercase text-muted small px-3 mt-2">Administration</li>

                        {# ── Admin: User Management (NEW) ── #}
                        <li class="nav-item">
                            <a href="{{ path('admin_user_index') }}" class="nav-link">
                                <i class="nav-icon bi bi-people-fill text-danger"></i>
                                <p>Manage Users</p>
                            </a>
                        </li>

                        {# ── Admin: Insurance ── #}
                        <li class="nav-item has-treeview">
                            <a href="#" class="nav-link">
                                <i class="nav-icon bi bi-shield-lock-fill text-danger"></i>
                                <p>Admin Insurance <i class="nav-arrow bi bi-chevron-right ms-auto"></i></p>
                            </a>
                            <ul class="nav nav-treeview ps-3">
                                <li class="nav-item">
                                    <a href="{{ path('admin_insurance_requests') }}" class="nav-link">
                                        <i class="nav-icon bi bi-file-earmark-check"></i>
                                        <p>All Requests</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('admin_insurance_packages') }}" class="nav-link">
                                        <i class="nav-icon bi bi-collection-fill"></i>
                                        <p>Manage Packages</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('admin_insurance_assets') }}" class="nav-link">
                                        <i class="nav-icon bi bi-hdd-network"></i>
                                        <p>All Assets</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        {# ── Admin: Loans ── #}
                        <li class="nav-item has-treeview">
                            <a href="#" class="nav-link">
                                <i class="nav-icon bi bi-bank2 text-danger"></i>
                                <p>Admin Loans <i class="nav-arrow bi bi-chevron-right ms-auto"></i></p>
                            </a>
                            <ul class="nav nav-treeview ps-3">
                                <li class="nav-item">
                                    <a href="{{ path('admin_loan_index') }}" class="nav-link">
                                        <i class="nav-icon bi bi-table"></i>
                                        <p>All Loans</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('admin_loan_repayments') }}" class="nav-link">
                                        <i class="nav-icon bi bi-calendar2-check"></i>
                                        <p>All Repayments</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        {# ── Admin: Roles ── #}
                        <li class="nav-item has-treeview">
                            <a href="#" class="nav-link">
                                <i class="nav-icon bi bi-shield-lock text-danger"></i>
                                <p>Manage Roles <i class="nav-arrow bi bi-chevron-right ms-auto"></i></p>
                            </a>
                            <ul class="nav nav-treeview ps-3">
                                <li class="nav-item">
                                    <a href="{{ path('admin_role_index') }}" class="nav-link">
                                        <i class="nav-icon bi bi-list-ul"></i>
                                        <p>All Roles</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('admin_role_users') }}" class="nav-link">
                                        <i class="nav-icon bi bi-people"></i>
                                        <p>Assign Roles</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        {# ── Admin: Finance ── #}
                        <li class="nav-item has-treeview">
                            <a href="#" class="nav-link">
                                <i class="nav-icon bi bi-piggy-bank-fill text-danger"></i>
                                <p>Admin Finance <i class="nav-arrow bi bi-chevron-right ms-auto"></i></p>
                            </a>
                            <ul class="nav nav-treeview ps-3">
                                <li class="nav-item">
                                    <a href="{{ path('admin_finance_budgets') }}" class="nav-link">
                                        <i class="nav-icon bi bi-wallet2"></i>
                                        <p>All Budgets</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('admin_finance_expenses') }}" class="nav-link">
                                        <i class="nav-icon bi bi-receipt"></i>
                                        <p>All Expenses</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('admin_finance_bills') }}" class="nav-link">
                                        <i class="nav-icon bi bi-file-earmark-text"></i>
                                        <p>All Bills</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        {# ── Admin: Pay & Complaints ── #}
                        <li class="nav-item has-treeview">
                            <a href="#" class="nav-link">
                                <i class="nav-icon bi bi-grid-1x2-fill text-danger"></i>
                                <p>Pay &amp; Complaints <i class="nav-arrow bi bi-chevron-right ms-auto"></i></p>
                            </a>
                            <ul class="nav nav-treeview ps-3">
                                <li class="nav-item">
                                    <a href="{{ path('admin_payment_index') }}" class="nav-link">
                                        <i class="nav-icon bi bi-credit-card-fill"></i>
                                        <p>All Payments</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="{{ path('admin_complaint_index') }}" class="nav-link">
                                        <i class="nav-icon bi bi-megaphone-fill"></i>
                                        <p>All Complaints</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        {% endif %}{# end ROLE_ADMIN #}

                    </ul>
                </nav>
            </div>

            {# Sign out pinned at bottom #}
            <div class="p-3 border-top border-secondary">
                <a href="{{ path('app_logout') }}" class="btn btn-outline-danger w-100">
                    <i class="bi bi-box-arrow-right me-2"></i>Sign out
                </a>
            </div>

        </div>
    </aside>

    {# ===== MAIN CONTENT ===== #}
    <main class="app-main">
        <div class="app-content-header">
            <div class="container-fluid">
                <h3 class="mb-0">{% block page_title %}Dashboard{% endblock %}</h3>
            </div>
        </div>
        <div class="app-content">
            <div class="container-fluid">
                {% block body %}{% endblock %}
            </div>
        </div>
    </main>

    <footer class="app-footer">
        <strong>MyApp</strong> © {{ "now"|date("Y") }}
    </footer>

</div>

{# AdminLTE JS (includes Bootstrap 5) #}
<script src="{{ asset('adminlte/js/adminlte.min.js') }}"></script>

{# Load DiceBear avatar in navbar #}
<script>
(function () {
    const img      = document.getElementById('navAvatarImg');
    const fallback = document.getElementById('navAvatarFallback');
    if (!img) return;
    const seed = img.dataset.seed || 'User';
    img.onload  = () => { fallback.style.display = 'none'; img.style.display = 'block'; };
    img.onerror = () => { /* keep initials fallback */ };
    img.src = `https://api.dicebear.com/9.x/pixel-art/png?seed=${seed}&size=34`;
})();
</script>

{% block javascripts %}{% endblock %}
</body>
</html>
