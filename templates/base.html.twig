{# base.html.twig #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Finance App{% endblock %}</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    {% block stylesheets %}{% endblock %}
</head>
<body>

<!-- TOP NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">

        <a class="navbar-brand" href="{{ path('app_home') }}">MyApp</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarContent">

            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                <!-- HOME -->
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_home') }}">
                        <i class="bi bi-speedometer2 me-1"></i>Dashboard
                    </a>
                </li>

                <!-- INSURANCE DROPDOWN -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-shield-check me-1"></i>Insurance
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="{{ path('insurance_assets') }}">My Insured Assets</a></li>
                        <li><a class="dropdown-item" href="{{ path('insurance_asset_new') }}">Register New Asset</a></li>
                    </ul>
                </li>

                <!-- LOANS DROPDOWN -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-bank me-1"></i>Loans
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="{{ path('loan_index') }}">My Loans</a></li>
                        <li><a class="dropdown-item" href="{{ path('loan_new') }}">Request Loan</a></li>
                        <li><a class="dropdown-item" href="{{ path('loan_index') }}">My Repayments</a></li>
                        <li><a class="dropdown-item" href="{{ path('loan_dashboard') }}">Loan Dashboard</a></li>
                    </ul>
                </li>

                <!-- PERSONAL FINANCE DROPDOWN -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-wallet2 me-1"></i>Personal Finance
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="{{ path('finance_budgets') }}">My Budgets</a></li>
                        <li><a class="dropdown-item" href="{{ path('finance_budget_new') }}">New Budget</a></li>
                    </ul>
                </li>

                <!-- PAYMENTS & COMPLAINTS DROPDOWN -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-chat-dots me-1"></i>Pay & Complaints
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="{{ path('payment_index') }}">Payments</a></li>
                        <li><a class="dropdown-item" href="{{ path('complaint_index') }}">Complaints</a></li>
                    </ul>
                </li>

            </ul>

            <!-- USER -->
            <ul class="navbar-nav ms-auto">
                {% if app.user %}
                    <li class="nav-item">
                        <span class="nav-link text-light">
                            <i class="bi bi-person-circle me-1"></i>{{ app.user.email }}
                        </span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_logout') }}">
                            <i class="bi bi-box-arrow-right me-1"></i>Logout
                        </a>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Login
                        </a>
                    </li>
                {% endif %}
            </ul>

        </div>
    </div>
</nav>

<!-- MAIN CONTENT -->
<div class="container mt-4">
    {% block body %}{% endblock %}
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

{% block javascripts %}{% endblock %}

</body>
</html>