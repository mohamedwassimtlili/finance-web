{% extends 'base.html.twig' %}

{% block title %}New Payment{% endblock %}
{% block page_title %}New Payment{% endblock %}

{% block body %}
{% for msg in app.flashes('error') %}<div class="alert alert-danger alert-dismissible fade show">{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>{% endfor %}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h3 class="card-title mb-0"><i class="bi bi-plus-circle me-2"></i>Record a Payment</h3>
            </div>
            <div class="card-body">
                <form method="post" action="{{ path('payment_new') }}" id="paymentForm" novalidate>

                    <div class="mb-3">
                        <label for="amount" class="form-label fw-semibold">Amount (TND) <span class="text-danger">*</span></label>
                        <div class="input-group has-validation">
                            <input type="number" step="0.001" min="0.001" max="9999999" name="amount" id="amount"
                                   class="form-control form-control-lg" required placeholder="0.000">
                            <span class="input-group-text">TND</span>
                            <div class="invalid-feedback">Please enter a valid positive amount (e.g. 50.000).</div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="type" class="form-label fw-semibold">Payment Type <span class="text-danger">*</span></label>
                        <select name="type" id="type" class="form-select" required>
                            <option value="" disabled selected>— Select type —</option>
                            <option value="payment">Payment</option>
                            <option value="transfer">Transfer</option>
                            <option value="refund">Refund</option>
                            <option value="deposit">Deposit</option>
                            <option value="withdrawal">Withdrawal</option>
                        </select>
                        <div class="invalid-feedback">Please select a payment type.</div>
                    </div>

                    <div class="mb-3">
                        <label for="status" class="form-label fw-semibold">Status <span class="text-danger">*</span></label>
                        <select name="status" id="status" class="form-select" required>
                            <option value="COMPLETED">Completed</option>
                            <option value="PENDING">Pending</option>
                            <option value="FAILED">Failed</option>
                            <option value="CANCELLED">Cancelled</option>
                        </select>
                        <div class="invalid-feedback">Please select a status.</div>
                    </div>

                    <div class="mb-3">
                        <label for="currency" class="form-label fw-semibold">Currency</label>
                        <select name="currency" id="currency" class="form-select">
                            <option value="TND" selected>TND – Tunisian Dinar</option>
                            <option value="USD">USD – US Dollar</option>
                            <option value="EUR">EUR – Euro</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label for="description" class="form-label fw-semibold d-flex justify-content-between">
                            <span>Description <small class="text-muted fw-normal">(optional)</small></span>
                            <span class="text-muted small fw-normal" id="desc-counter">0 / 500</span>
                        </label>
                        <textarea name="description" id="description" class="form-control" rows="3"
                                  placeholder="Optional note about this payment…" maxlength="500"
                                  oninput="updateCounter('description','desc-counter',500)"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill" id="submitBtn">
                            <i class="bi bi-check-circle me-1"></i> Save Payment
                        </button>
                        <a href="{{ path('payment_index') }}" class="btn btn-outline-secondary flex-fill">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    const form = document.getElementById('paymentForm');

    // Real-time validation on blur/input
    form.querySelectorAll('input, select, textarea').forEach(el => {
        el.addEventListener('blur', () => validateField(el));
        el.addEventListener('input', () => { if (el.classList.contains('is-invalid')) validateField(el); });
    });

    form.addEventListener('submit', function (e) {
        e.preventDefault();
        let valid = true;
        form.querySelectorAll('input[required], select[required]').forEach(el => {
            if (!validateField(el)) valid = false;
        });
        if (valid) form.submit();
    });

    function validateField(el) {
        const ok = el.checkValidity();
        el.classList.toggle('is-valid',   ok);
        el.classList.toggle('is-invalid', !ok);
        return ok;
    }
})();

function updateCounter(inputId, counterId, max) {
    const len = document.getElementById(inputId).value.length;
    const el  = document.getElementById(counterId);
    el.textContent = len + ' / ' + max;
    el.classList.toggle('text-danger', len >= max * 0.9);
}
</script>
{% endblock %}
