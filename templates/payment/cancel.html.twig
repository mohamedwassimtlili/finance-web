{% extends 'base.html.twig' %}

{% block title %}Payment Cancelled{% endblock %}
{% block page_title %}Payment Cancelled{% endblock %}

{% block body %}
<div class="row justify-content-center mt-4">
    <div class="col-lg-6 text-center">
        <div class="text-danger mb-3"><i class="bi bi-x-circle-fill" style="font-size:5rem;"></i></div>
        <h2 class="text-danger">Payment Cancelled</h2>
        <p class="text-muted">You cancelled the payment. No amount has been charged.</p>
        <div class="d-flex justify-content-center gap-3 mt-4">
            <a href="{{ path('payment_create') }}" class="btn btn-primary">
                <i class="bi bi-arrow-repeat me-1"></i>Try Again
            </a>
            <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">
                <i class="bi bi-house me-1"></i>Dashboard
            </a>
        </div>
    </div>
</div>
{% endblock %}
