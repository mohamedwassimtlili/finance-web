{% extends 'base.html.twig' %}

{% block title %}Payment {{ verified ? 'Successful' : 'Processing' }}{% endblock %}
{% block page_title %}Payment Result{% endblock %}

{% block body %}
<div class="row justify-content-center mt-4">
    <div class="col-lg-6 text-center">
        {% if verified %}
            <div class="text-success mb-3"><i class="bi bi-check-circle-fill" style="font-size:5rem;"></i></div>
            <h2 class="text-success">Payment Successful!</h2>
            <p class="text-muted">Your payment has been processed and confirmed by Paymee.</p>
        {% else %}
            <div class="text-warning mb-3"><i class="bi bi-hourglass-split" style="font-size:5rem;"></i></div>
            <h2 class="text-warning">Payment Processing</h2>
            <p class="text-muted">Your payment is being verified. Check your payment history for the final status.</p>
        {% endif %}
        <div class="d-flex justify-content-center gap-3 mt-4">
            <a href="{{ path('payment_index') }}" class="btn btn-primary">
                <i class="bi bi-list-ul me-1"></i>My Payments
            </a>
            <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">
                <i class="bi bi-house me-1"></i>Dashboard
            </a>
        </div>
    </div>
</div>
{% endblock %}
