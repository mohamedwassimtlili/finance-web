{% extends 'base.html.twig' %}

{% block title %}Make a Payment{% endblock %}
{% block page_title %}Make a Payment{% endblock %}

{% block body %}
{% for msg in app.flashes('error') %}<div class="alert alert-danger alert-dismissible fade show">{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>{% endfor %}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h3 class="card-title mb-0"><i class="bi bi-credit-card me-2"></i>Secure Payment via Paymee</h3>
            </div>
            <div class="card-body">
                <div class="alert alert-info d-flex align-items-center gap-2 mb-4">
                    <i class="bi bi-shield-lock-fill fs-4"></i>
                    <div>Your payment is secured by <strong>Paymee</strong> — Tunisia's leading payment gateway. You will be redirected to complete the payment securely.</div>
                </div>

                <form method="post" action="{{ path('payment_create') }}">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Amount (TND) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="number" step="0.001" min="0.01" name="amount" class="form-control form-control-lg"
                                   required placeholder="0.000">
                            <span class="input-group-text">TND</span>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Payment Note <span class="text-danger">*</span></label>
                        <input type="text" name="note" class="form-control" required
                               placeholder="e.g. Loan repayment, Insurance premium…" maxlength="100">
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-arrow-right-circle me-2"></i>Proceed to Paymee
                        </button>
                        <a href="{{ path('payment_index') }}" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
            <div class="card-footer text-center text-muted small">
                <i class="bi bi-lock-fill me-1"></i>Encrypted &amp; secure — powered by
                <strong>Paymee Sandbox</strong>
            </div>
        </div>
    </div>
</div>
{% endblock %}
