<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Financial Report</title>
    <style>
        body { font-family: Helvetica, Arial, sans-serif; color: #333; line-height: 1.5; font-size: 14px; }
        .header { text-align: center; margin-bottom: 30px; border-bottom: 2px solid #0d6efd; padding-bottom: 10px; }
        .header h1 { margin: 0; color: #0d6efd; }
        .header p { margin: 5px 0 0; color: #666; font-size: 12px; }
        .summary-box { width: 48%; float: left; border: 1px solid #ddd; padding: 15px; margin-bottom: 20px; border-radius: 5px; box-sizing: border-box; }
        .summary-box.right { float: right; }
        .summary-box h3 { margin-top: 0; font-size: 16px; border-bottom: 1px solid #eee; padding-bottom: 5px; color: #444; }
        .stat-row { margin-bottom: 8px; }
        .stat-label { font-weight: bold; display: inline-block; width: 150px; }
        .stat-value { color: #000; }
        .clear { clear: both; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th { background-color: #f8f9fa; color: #333; text-align: left; padding: 10px; border-bottom: 2px solid #dee2e6; font-size: 13px; }
        td { padding: 10px; border-bottom: 1px solid #eee; font-size: 13px; }
        tr:nth-child(even) td { background-color: #fdfdfd; }
        .badge { padding: 3px 8px; border-radius: 12px; font-size: 11px; font-weight: bold; display: inline-block; }
        .bg-success { background-color: #198754; color: white; }
        .bg-warning { background-color: #ffc107; color: #000; }
        .bg-danger { background-color: #dc3545; color: white; }
        .bg-info { background-color: #0dcaf0; color: #000; }
        .text-right { text-align: right; }
        .amount-positive { color: #0d7a52; }
        .amount-negative { color: #b91c1c; }
    </style>
</head>
<body>

    <div class="header">
        <h1>Financial Summary Report</h1>
        <p>Generated on {{ "now"|date("F j, Y, g:i a") }}</p>
    </div>

    <div class="summary-box">
        <h3>Budget Overview</h3>
        <div class="stat-row">
            <span class="stat-label">Total Allocated:</span>
            <span class="stat-value">{{ totalBudget|number_format(2) }} TND</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Total Spent:</span>
            <span class="stat-value">{{ totalSpent|number_format(2) }} TND</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Remaining:</span>
            <span class="stat-value {% if totalRemaining < 0 %}amount-negative{% else %}amount-positive{% endif %}">
                {{ totalRemaining|number_format(2) }} TND
            </span>
        </div>
        <div class="stat-row" style="margin-top: 15px;">
            <span class="stat-label">Health Score:</span>
            <span class="stat-value" style="font-weight: bold; color: {% if healthScore >= 80 %}green{% elseif healthScore >= 40 %}orange{% else %}red{% endif %};">{{ healthScore }}/100 ({{ healthStatus }})</span>
        </div>
    </div>

    <div class="summary-box right">
        <h3>Spending Patterns</h3>
        <div class="stat-row">
            <span class="stat-label">Total Transactions:</span>
            <span class="stat-value">{{ expenses|length }}</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Average Expense:</span>
            <span class="stat-value">{{ avgExpense|number_format(2) }} TND</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Highest Expense:</span>
            <span class="stat-value">{{ highestExpense|number_format(2) }} TND</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Top Category:</span>
            <span class="stat-value">{{ biggestCategory|default('N/A') }}</span>
        </div>
    </div>

    <div class="clear"></div>

    <h3 style="margin-top: 30px; border-bottom: 2px solid #eee; padding-bottom: 5px;">Your Budgets</h3>
    <table>
        <thead>
            <tr>
                <th>Budget Name</th>
                <th>Category</th>
                <th>Allocated</th>
                <th>Spent</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            {% for budget in budgets %}
            <tr>
                <td>{{ budget.name }}</td>
                <td>{{ budget.category|default('Uncategorized') }}</td>
                <td>{{ budget.amount|number_format(2) }} TND</td>
                <td>{{ budget.spentAmount|number_format(2) }} TND</td>
                <td>
                    {% set status = budget.status %}
                    <span class="badge {% if status == 'On Track' %}bg-success{% elseif status == 'Warning' %}bg-warning{% elseif status == 'Near Limit' %}bg-info{% else %}bg-danger{% endif %}">{{ status }}</span>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="5" style="text-align: center;">No budgets found.</td></tr>
            {% endfor %}
        </tbody>
    </table>

    <h3 style="margin-top: 40px; border-bottom: 2px solid #eee; padding-bottom: 5px;">Recent Expenses (Top 50)</h3>
    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Budget</th>
                <th>Category</th>
                <th>Description</th>
                <th class="text-right">Amount</th>
            </tr>
        </thead>
        <tbody>
            {% for expense in expenses|slice(0, 50) %}
            <tr>
                <td>{{ expense.expenseDate|date('Y-m-d') }}</td>
                <td>{{ expense.budget.name }}</td>
                <td>{{ expense.category|default('-') }}</td>
                <td>{{ expense.description|default('-') }}</td>
                <td class="text-right">{{ expense.amount|number_format(2) }} TND</td>
            </tr>
            {% else %}
            <tr><td colspan="5" style="text-align: center;">No expenses found.</td></tr>
            {% endfor %}
        </tbody>
    </table>

</body>
</html>
